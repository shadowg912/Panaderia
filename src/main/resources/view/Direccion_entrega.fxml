<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="CHECKOUT"/>
                <Label styleClass="header-title" text="Dirección de Entrega"/>
                <Label styleClass="text-accent" text="Cliente: [Nombre del cliente]"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 32;">
            <children>
                <VBox styleClass="card">
                    <children>
                        <Label styleClass="card-title" text="Direcciones Guardadas"/>
                        <VBox spacing="10">
                            <children>
                                <RadioButton selected="true" styleClass="radio-light" text="Calle Principal #123, Zona Colonial, Santo Domingo"/>
                                <RadioButton styleClass="radio-light" text="Av. Independencia #456, Ensanche Naco, Santo Domingo"/>
                                <RadioButton styleClass="radio-light" text="Calle Duarte #789, Los Alcarrizos"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox styleClass="card">
                    <children>
                        <Label styleClass="card-title" text="Nueva Dirección"/>
                        <GridPane styleClass="form-grid">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="110"/>
                                <ColumnConstraints hgrow="ALWAYS" maxWidth="420"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints/>
                                <RowConstraints/>
                                <RowConstraints/>
                                <RowConstraints/>
                                <RowConstraints/>
                            </rowConstraints>
                            <children>
                                <Label styleClass="form-label" text="Calle"/>
                                <TextField GridPane.columnIndex="1"/>
                                <Label styleClass="form-label" text="Número" GridPane.rowIndex="1"/>
                                <TextField GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label styleClass="form-label" text="Ciudad" GridPane.rowIndex="2"/>
                                <TextField GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <Label styleClass="form-label" text="Provincia" GridPane.rowIndex="3"/>
                                <ComboBox maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <Label styleClass="form-label" text="País" GridPane.rowIndex="4"/>
                                <TextField editable="false" text="República Dominicana" styleClass="text-readonly" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </children>
                        </GridPane>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="info-box">
                    <children>
                        <Label styleClass="form-label" text="Costo de Envío:"/>
                        <Label styleClass="card-title" text="RD$ 150.00"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="16">
                    <children>
                        <Button text="Volver" styleClass="btn, btn-secondary"/>
                        <Button text="Continuar" styleClass="btn, btn-primary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>