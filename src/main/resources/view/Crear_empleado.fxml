<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Crear_empleado_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — ADMINISTRACIÓN"/>
                <Label styleClass="header-title" text="Registro de Empleado"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 40;">
                    <VBox spacing="16" styleClass="card" style="-fx-min-width: 500; -fx-max-width: 550;">
                        <children>
                            <Label styleClass="card-title" text="Datos del Empleado"/>
                            <GridPane styleClass="form-grid">
                                <columnConstraints>
                                    <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="150"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                    <RowConstraints/>
                                </rowConstraints>
                                <children>
                                    <Label styleClass="form-label" text="Nombre *" GridPane.rowIndex="0"/>
                                    <TextField fx:id="txtNombre" promptText="Ej: Juan" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                    <Label styleClass="form-label" text="Primer Apellido *" GridPane.rowIndex="1"/>
                                    <TextField fx:id="txtApellido1" promptText="Ej: Pérez" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                    <Label styleClass="form-label" text="Segundo Apellido" GridPane.rowIndex="2"/>
                                    <TextField fx:id="txtApellido2" promptText="Ej: García" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                    <Label styleClass="form-label" text="Teléfono" GridPane.rowIndex="3"/>
                                    <TextField fx:id="txtTelefono" promptText="Ej: 809-000-0000" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                    <Label styleClass="form-label" text="Puesto" GridPane.rowIndex="4"/>
                                    <ComboBox fx:id="cmbPuesto" maxWidth="Infinity" prefHeight="42" promptText="Seleccione puesto" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                </children>
                            </GridPane>

                            <HBox alignment="CENTER" spacing="16" style="-fx-padding: 10 0 0 0;">
                                <children>
                                    <Button fx:id="btnLimpiar" onAction="#fnLimpiar" text="Limpiar" styleClass="btn, btn-secondary"/>
                                    <Button fx:id="btnCancelar" onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
                                    <Button fx:id="btnCrearEmpleado" onAction="#fnCrearEmpleado" text="Crear Empleado" styleClass="btn, btn-primary"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>