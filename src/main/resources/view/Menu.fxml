<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.menu_contoller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar" style="-fx-padding: 16 32;">
            <children>
                <VBox>
                    <Label styleClass="header-title" text="Panel Principal"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="12">
                    <Label styleClass="text-body" style="-fx-font-weight: bold;" text="Usuario Administrador"/>
                    <Circle fill="#cdb08e" radius="18"/>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox spacing="32" style="-fx-padding: 40;">
                    <children>
                        <Label styleClass="section-title" text="MÓDULOS DEL SISTEMA"/>

                        <FlowPane hgap="24" prefWrapLength="1100" vgap="24">
                            <children>
                                <VBox spacing="15" styleClass="menu-card">
                                    <Label styleClass="card-title" text="VENTAS"/>
                                    <Button fx:id="btnNuevaOrden" maxWidth="Infinity" onAction="#fnIrCrearOrden" text="Nueva Orden" styleClass="btn, btn-primary"/>
                                    <Button fx:id="btnHistorialVenta" maxWidth="Infinity" onAction="#fnIrHistorialVentas" text="Historial de Ventas" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnSeguimientroEnvio" maxWidth="Infinity" onAction="#fnIrSeguimientoEnvio" text="Seguimiento Envíos" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnGuardarDIrecciones" maxWidth="Infinity" onAction="#fnIrGuardarDIrecciones" text="Guardar Direcciones" styleClass="btn, btn-ghost"/>
                                </VBox>

                                <VBox spacing="15" styleClass="menu-card">
                                    <Label styleClass="card-title" text="INVENTARIO"/>
                                    <Button fx:id="btnRegistroProducto" maxWidth="Infinity" onAction="#fnIrRegistrarProducto" text="Registro Producto" styleClass="btn, btn-primary"/>
                                    <Button fx:id="btnVerInventario" maxWidth="Infinity" onAction="#fnIrVerInventario" text="Ver Inventario" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnRegistroProveedores" maxWidth="Infinity" onAction="#fnIrRegistroProveedores" text="Proveedores" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnRegistroRecetas" maxWidth="Infinity" onAction="#fnIrRegistroRecetas" text="Recetas" styleClass="btn, btn-ghost"/>
                                </VBox>

                                <VBox spacing="15" styleClass="menu-card">
                                    <Label styleClass="card-title" text="PRODUCCIÓN"/>
                                    <Button fx:id="btnOrdenProduccion" maxWidth="Infinity" onAction="#fnIrOrdenProduccion" text="Nueva Orden" styleClass="btn, btn-primary"/>
                                    <Button fx:id="btnVerOrdenesProduccion" maxWidth="Infinity" onAction="#fnIrVerOrdenesProduccion" text="Ver Órdenes" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnVerRecetas" maxWidth="Infinity" onAction="#fnIrVerRecetas" text="Ver Recetas" styleClass="btn, btn-ghost"/>
                                </VBox>

                                <VBox spacing="15" styleClass="menu-card">
                                    <Label styleClass="card-title" text="CLIENTES"/>
                                    <Button fx:id="btnRegistroCliente" maxWidth="Infinity" onAction="#fnIrRegistroCliente" text="Registro Cliente" styleClass="btn, btn-primary"/>
                                    <Button fx:id="btnGestionClientes" maxWidth="Infinity" onAction="#fnIrGestionClientes" text="Gestionar Clientes" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnReclamaciones" maxWidth="Infinity" onAction="#fnIrReclamaciones" text="Reclamaciones" styleClass="btn, btn-ghost"/>
                                </VBox>

                                <VBox spacing="15" styleClass="menu-card">
                                    <Label styleClass="card-title" text="SISTEMA"/>
                                    <Button fx:id="btnCrearUsuario" maxWidth="Infinity" onAction="#fnIrCrearUsuario" text="Crear Usuario" styleClass="btn, btn-primary"/>
                                    <Button fx:id="btnAdminUsuarios" maxWidth="Infinity" onAction="#fnIrAdminUsuarios" text="Administrar Usuarios" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnAdminEmpleados" maxWidth="Infinity" onAction="#fnIrAdminEmpleados" text="Administrar Empleados" styleClass="btn, btn-ghost"/>
                                    <Button fx:id="btnCrearEmpleado" maxWidth="Infinity" onAction="#fnIrCrearEmpleado" text="Crear Empleado" styleClass="btn, btn-ghost"/>
                                    <Button maxWidth="Infinity" text="Cerrar Sesión" styleClass="btn, btn-danger"/>
                                </VBox>
                            </children>
                        </FlowPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>