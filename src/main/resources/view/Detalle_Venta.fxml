<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Detalle_orden_venta_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — VENTAS"/>
                <Label styleClass="header-title" text="Agregar Productos a la Orden"/>
                <Label fx:id="lblInfoOrden" styleClass="text-accent" text="Orden #"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="32" style="-fx-padding: 40;">
            <children>
                <HBox spacing="32" alignment="TOP_CENTER">
                    <VBox spacing="20" styleClass="card" style="-fx-min-width: 500;">
                        <children>
                            <Label styleClass="card-title" text="Seleccionar Producto"/>
                            <VBox spacing="12">
                                <Label styleClass="form-label" text="Producto *"/>
                                <ComboBox fx:id="cmbProducto" promptText="Seleccione un producto..." prefHeight="52" maxWidth="Infinity"/>
                            </VBox>
                            <HBox spacing="16">
                                <VBox spacing="12" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Cantidad *"/>
                                    <TextField fx:id="txtCantidad" promptText="0.00" prefHeight="52"/>
                                </VBox>
                                <VBox spacing="12" HBox.hgrow="ALWAYS">
                                    <Label styleClass="form-label" text="Precio Unitario"/>
                                    <TextField fx:id="txtPrecioUnitario" editable="false" promptText="RD$ 0.00" prefHeight="52" styleClass="text-accent"/>
                                </VBox>
                            </HBox>
                            <Button fx:id="btnAgregarProducto" onAction="#fnAgregarProducto" prefHeight="52" maxWidth="Infinity" styleClass="btn, btn-success" text="Agregar Producto"/>
                        </children>
                    </VBox>

                    <VBox spacing="20" styleClass="card" style="-fx-min-width: 500;">
                        <children>
                            <Label styleClass="card-title" text="Productos Agregados"/>
                            <TableView fx:id="tblDetalle" prefHeight="300" styleClass="table-view">
                                <columns>
                                    <TableColumn fx:id="colProducto" prefWidth="200" text="Producto"/>
                                    <TableColumn fx:id="colCantidad" prefWidth="100" text="Cantidad"/>
                                    <TableColumn fx:id="colPrecio" prefWidth="120" text="P. Unitario"/>
                                    <TableColumn fx:id="colSubtotal" prefWidth="120" text="Subtotal"/>
                                </columns>
                            </TableView>
                            <VBox spacing="12" styleClass="card" style="-fx-padding: 20;">
                                <HBox>
                                    <Label styleClass="form-label" text="Subtotal:" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblSubtotal" styleClass="text-body" style="-fx-font-weight: bold;" text="RD$ 0.00"/>
                                </HBox>
                                <HBox>
                                    <Label styleClass="form-label" text="ITBIS (18%):" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblItbis" styleClass="text-body" style="-fx-font-weight: bold;" text="RD$ 0.00"/>
                                </HBox>
                                <Separator styleClass="separator-dark"/>
                                <HBox>
                                    <Label styleClass="card-title" text="Total:" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotal" styleClass="card-title" text="RD$ 0.00"/>
                                </HBox>
                            </VBox>
                        </children>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <children>
                        <Button fx:id="btnVolver" onAction="#fnVolver" prefHeight="52" text="Volver" styleClass="btn, btn-secondary"/>
                        <Button fx:id="btnConfirmarOrden" onAction="#fnConfirmarOrden" prefHeight="52" text="Confirmar Orden" styleClass="btn, btn-primary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>