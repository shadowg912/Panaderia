<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Movimientos_inventario_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — INVENTARIO"/>
            <Label styleClass="header-title" text="Historial de Movimientos"/>
            <Label styleClass="text-accent" text="Entradas y salidas de inventario"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5">
                    <Label styleClass="label-small" text="FILTRAR PRODUCTO"/>
                    <ComboBox fx:id="cmbFiltroMovimiento" prefWidth="250" promptText="Todos los productos"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="label-small" text="TIPO"/>
                    <ComboBox fx:id="cmbTipoMovimiento" onAction="#fnFiltrar" prefWidth="150" promptText="Todos"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
            </HBox>

            <TableView fx:id="tablaMovimientos" prefHeight="550" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colMovFecha" prefWidth="140" text="FECHA"/>
                    <TableColumn fx:id="colMovProducto" prefWidth="200" text="PRODUCTO"/>
                    <TableColumn fx:id="colMovTipo" prefWidth="100" text="TIPO"/>
                    <TableColumn fx:id="colMovCantidad" prefWidth="100" text="CANTIDAD"/>
                    <TableColumn fx:id="colMovStock" prefWidth="100" text="STOCK RESULTANTE"/>
                    <TableColumn fx:id="colMovUsuario" prefWidth="150" text="USUARIO"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 6 0 0 0;">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 movimientos"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
