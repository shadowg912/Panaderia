<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Ventana_pagos_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — VENTAS"/>
            <Label styleClass="header-title" text="Registro de Pagos"/>
            <Label styleClass="text-accent" text="Seleccione un cliente y registre pagos de facturas pendientes"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">

            <!-- Selector de cliente -->
            <HBox spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-small" text="CLIENTE"/>
                    <ComboBox fx:id="cmbCliente" onAction="#fnClienteSeleccionado"
                              promptText="Seleccione un cliente" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <!-- Tabla de facturas pendientes -->
            <TableView fx:id="tblFacturas" prefHeight="480" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colSeleccion" prefWidth="50" text=""/>
                    <TableColumn fx:id="colNumFactura" prefWidth="180" text="N° FACTURA"/>
                    <TableColumn fx:id="colFecha" prefWidth="130" text="FECHA"/>
                    <TableColumn fx:id="colTotal" prefWidth="160" text="TOTAL (RD$)"/>
                    <TableColumn fx:id="colPagado" prefWidth="160" text="PAGADO (RD$)"/>
                    <TableColumn fx:id="colSaldo" prefWidth="160" text="SALDO PENDIENTE (RD$)"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="Seleccione un cliente para ver sus facturas pendientes"/>
                </placeholder>
            </TableView>

            <!-- Barra de resumen y accion -->
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <Label fx:id="lblSeleccionadas" styleClass="section-title" text="0 facturas seleccionadas"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTotalPendiente" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #100e0a;"
                       text="Total pendiente: RD$ 0.00"/>
                <Button fx:id="btnPagar" disable="true" onAction="#fnPagar"
                        text="Pagar Seleccionadas" styleClass="btn, btn-primary"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar">
            <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-ghost"/>
        </HBox>
    </bottom>
</BorderPane>
