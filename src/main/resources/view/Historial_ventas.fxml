<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Historial_ventas_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — VENTAS"/>
            <Label styleClass="header-title" text="Historial de Ventas"/>
            <Label styleClass="text-accent" text="Consulta de órdenes de venta realizadas"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5">
                    <Label styleClass="label-small" text="ESTADO"/>
                    <ComboBox fx:id="cmbEstado" onAction="#fnFiltrar" prefWidth="150" promptText="Todos los estados"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="label-small" text="DESDE"/>
                    <DatePicker fx:id="dpDesde" prefWidth="150"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="label-small" text="HASTA"/>
                    <DatePicker fx:id="dpHasta" prefWidth="150"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#fnFiltrar" text="Buscar" styleClass="btn, btn-primary"/>
                <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
            </HBox>

            <TableView fx:id="tablaVentas" prefHeight="500" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="80" text="ID"/>
                    <TableColumn fx:id="colFecha" prefWidth="180" text="FECHA"/>
                    <TableColumn fx:id="colCliente" prefWidth="350" text="CLIENTE"/>
                    <TableColumn fx:id="colTotal" prefWidth="150" text="TOTAL (RD$)"/>
                    <TableColumn fx:id="colEstado" prefWidth="150" text="ESTADO"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 6 0 0 0;">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 órdenes"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
