<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — REPORTES"/>
                <Label styleClass="header-title" text="Historial de Ventas"/>
                <Label styleClass="text-accent" text="Consulta y seguimiento de facturación emitida"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card">
                    <children>
                        <VBox spacing="5">
                            <Label styleClass="label-small" text="CLIENTE"/>
                            <ComboBox prefWidth="200" promptText="Todos los clientes"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label styleClass="label-small" text="DESDE"/>
                            <DatePicker prefWidth="150"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label styleClass="label-small" text="HASTA"/>
                            <DatePicker prefWidth="150"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Buscar Registros" styleClass="btn, btn-primary"/>
                    </children>
                </HBox>

                <TableView VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn prefWidth="130" text="Nº Factura"/>
                        <TableColumn prefWidth="130" text="Fecha"/>
                        <TableColumn prefWidth="300" text="Cliente"/>
                        <TableColumn prefWidth="150" text="Total (RD$)"/>
                        <TableColumn prefWidth="120" text="Estado"/>
                        <TableColumn prefWidth="150" text="Acciones"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 10 0;">
                    <children>
                        <Label styleClass="text-placeholder" text="Mostrando página 1 de 5"/>
                        <Button text="Anterior" styleClass="btn, btn-secondary"/>
                        <Button text="Siguiente" styleClass="btn, btn-secondary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>