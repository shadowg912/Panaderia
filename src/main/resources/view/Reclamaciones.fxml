<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #0f172a;">
    <top>
        <VBox style="-fx-background-color: #1e293b; -fx-padding: 16 24; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #38bdf8; -fx-letter-spacing: 2;" text="PANADERÍA — POSTVENTA"/>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;" text="Reclamaciones de Venta"/>
            </children>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.42" prefHeight="600" style="-fx-background-color: #0f172a; -fx-border-color: transparent;">
            <items>
                <!-- Panel izquierdo: Lista de reclamaciones -->
                <VBox spacing="14" style="-fx-padding: 24; -fx-background-color: #0f172a;">
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" text="Reclamaciones Recientes"/>
                        <TableView prefHeight="430" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <columns>
                                <TableColumn prefWidth="120" text="Nº Reclamo"/>
                                <TableColumn prefWidth="110" text="Factura"/>
                                <TableColumn prefWidth="110" text="Fecha"/>
                                <TableColumn prefWidth="100" text="Estado"/>
                                <TableColumn prefWidth="100" text="Prioridad"/>
                            </columns>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button style="-fx-background-color: #6366f1; -fx-text-fill: #fff3eb; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24;" text="+ Nuevo Reclamo"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <!-- Panel derecho: Detalle del reclamo -->
                <VBox spacing="14" style="-fx-padding: 24; -fx-background-color: #0f172a;">
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" text="Detalle de Reclamo"/>
                        <!-- Datos del reclamo -->
                        <VBox style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 20;">
                            <children>
                                <GridPane hgap="16" vgap="10">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="130"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>
                                    <children>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Nº Reclamo:" GridPane.rowIndex="0"/>
                                        <Label style="-fx-text-fill: #38bdf8; -fx-font-size: 13px; -fx-font-weight: bold;" text="RCL-2026-042" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Factura:" GridPane.rowIndex="1"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="FV-2026-0087" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Cliente:" GridPane.rowIndex="2"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Supermercados del Caribe SRL" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Fecha:" GridPane.rowIndex="3"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="16/02/2026" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Estado:" GridPane.rowIndex="4"/>
                                        <ComboBox maxWidth="Infinity" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                        <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Prioridad:" GridPane.rowIndex="5"/>
                                        <ComboBox maxWidth="Infinity" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                        <!-- Descripción -->
                        <VBox spacing="6">
                            <children>
                                <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px; -fx-font-weight: bold;" text="Descripción del problema"/>
                                <TextArea prefHeight="100" style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
                            </children>
                        </VBox>
                        <!-- Solución -->
                        <VBox spacing="6">
                            <children>
                                <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px; -fx-font-weight: bold;" text="Solución propuesta"/>
                                <TextArea prefHeight="100" style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
                            </children>
                        </VBox>
                        <!-- Botones -->
                        <HBox alignment="CENTER_RIGHT" spacing="14">
                            <children>
                                <Button style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 24;" text="Cancelar"/>
                                <Button style="-fx-background-color: #6366f1; -fx-text-fill: #fff3eb; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 11 24;" text="Guardar Cambios"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #1e293b; -fx-padding: 12; -fx-border-color: #334155; -fx-border-width: 1 0 0 0;"/>
    </bottom>
</BorderPane>