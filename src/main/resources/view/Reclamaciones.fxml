<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Reclamaciones_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — POSTVENTA"/>
                <Label styleClass="header-title" text="Gestión de Reclamaciones"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox alignment="TOP_CENTER" spacing="32" style="-fx-padding: 40;">
                    <HBox alignment="TOP_CENTER" spacing="32">
                        <VBox spacing="25" styleClass="card" style="-fx-min-width: 520;">
                            <children>
                                <Label styleClass="card-title" text="DATOS DE ORIGEN"/>

                                <VBox spacing="12">
                                    <Label styleClass="form-label" text="Órden de Venta *"/>
                                    <TextField fx:id="txtDatosOrden" id="txtDatosOrden" editable="false" styleClass="text-readonly" promptText="Busque una orden..."/>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <TextField fx:id="txtIdOrden" promptText="ID" prefWidth="80"/>
                                        <Button fx:id="btnBuscarOrden" onAction="#fnBuscarOrden" text="Buscar" styleClass="btn, btn-secondary" prefHeight="42"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="12">
                                    <Label styleClass="form-label" text="Cliente *"/>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <TextField fx:id="txtIdCliente" promptText="ID" prefWidth="80"/>
                                        <TextField fx:id="txtNombreCliente" editable="false" styleClass="text-readonly" HBox.hgrow="ALWAYS" promptText="Busque un cliente..."/>
                                        <Button fx:id="btnBuscarCliente" onAction="#fnBuscarCliente" text="Buscar" styleClass="btn, btn-secondary" prefHeight="42"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="12">
                                    <Label styleClass="form-label" text="Empleado Responsable"/>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <TextField fx:id="txtIdEmpleado" promptText="ID" prefWidth="80"/>
                                        <TextField fx:id="txtNombreEmpleado" editable="false" styleClass="text-readonly" HBox.hgrow="ALWAYS" promptText="Busque un empleado..."/>
                                        <Button fx:id="btnBuscarEmpleado" onAction="#fnBuscarEmpleado" text="Buscar" styleClass="btn, btn-secondary" prefHeight="42"/>
                                    </HBox>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="25" styleClass="card" style="-fx-min-width: 520;">
                            <children>
                                <Label styleClass="card-title" text="ESTADO Y PRIORIDAD"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="Tipo *" GridPane.rowIndex="0"/>
                                        <ComboBox fx:id="cmbTipo" maxWidth="Infinity" prefHeight="48" GridPane.columnIndex="1" GridPane.rowIndex="0" promptText="Seleccione tipo"/>

                                        <Label styleClass="form-label" text="Estado *" GridPane.rowIndex="1"/>
                                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity" prefHeight="48" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="Seleccione estado"/>

                                        <Label styleClass="form-label" text="Prioridad *" GridPane.rowIndex="2"/>
                                        <ComboBox fx:id="cmbPrioridad" maxWidth="Infinity" prefHeight="48" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="Seleccione prioridad"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </HBox>

                    <VBox maxWidth="1072" spacing="15" styleClass="card">
                        <children>
                            <Label styleClass="card-title" text="MOTIVO DEL RECLAMO"/>
                            <TextArea fx:id="txtMotivo" prefHeight="120" promptText="Describa el problema aquí..." wrapText="true"/>
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" maxWidth="1072" spacing="20">
                        <children>
                            <Button fx:id="btnLimpiar" onAction="#fnLimpiar" text="Limpiar" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnCancelar" onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnGuardar" onAction="#fnGuardarReclamacion" text="Guardar Reclamación" styleClass="btn, btn-primary"/>
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>