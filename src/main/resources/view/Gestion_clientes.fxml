<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Gestion_clientes_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — CLIENTES"/>
                <Label styleClass="header-title" text="Gestión de Clientes"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox alignment="TOP_CENTER" spacing="32" style="-fx-padding: 40;">

                    <VBox spacing="16" styleClass="card" style="-fx-min-width: 982; -fx-max-width: 1072;">
                        <children>
                            <Label styleClass="card-title" text="BUSCAR CLIENTE"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <VBox spacing="5" prefWidth="100">
                                    <Label styleClass="label-small" text="ID CLIENTE"/>
                                    <TextField fx:id="txtIdCliente" promptText="ID"/>
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-small" text="NOMBRE / RAZÓN SOCIAL"/>
                                    <TextField fx:id="txtNombreCliente" editable="false" styleClass="text-readonly"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: transparent;" text="."/>
                                    <Button fx:id="btnBuscarCliente" onAction="#fnBuscarCliente" text="Buscar" styleClass="btn, btn-secondary" prefHeight="42"/>
                                </VBox>
                            </HBox>
                        </children>
                    </VBox>

                    <HBox alignment="TOP_CENTER" spacing="32">
                        <VBox spacing="20" styleClass="card" style="-fx-min-width: 500;">
                            <children>
                                <Label styleClass="card-title" text="INFORMACIÓN GENERAL"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="130"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="Razón Social *" GridPane.rowIndex="0"/>
                                        <TextField fx:id="txtRazonSocial" promptText="Nombre legal de la empresa" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label styleClass="form-label" text="RNC *" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtRnc" promptText="1-01-XXXXX-X" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label styleClass="form-label" text="Teléfono" GridPane.rowIndex="2"/>
                                        <TextField fx:id="txtTelefono" promptText="809-XXX-XXXX" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label styleClass="form-label" text="Correo Electrónico" GridPane.rowIndex="3"/>
                                        <TextField fx:id="txtCorreo" promptText="ejemplo@empresa.com" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                    </children>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="20" styleClass="card" style="-fx-min-width: 450;">
                            <children>
                                <Label styleClass="card-title" text="UBICACIÓN FISCAL"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="120"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="Provincia *" GridPane.rowIndex="1"/>
                                        <ComboBox fx:id="cmbProvincia" onAction="#fnCambioProvincia" maxWidth="Infinity" prefHeight="42.0" promptText="Seleccione provincia" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label styleClass="form-label" text="Ciudad *" GridPane.rowIndex="2"/>
                                        <TextField fx:id="txtCiudad" promptText="Ej: Santiago de los Caballeros" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label styleClass="form-label" text="Sector *" GridPane.rowIndex="3"/>
                                        <TextField fx:id="txtSector" promptText="Ej: Ensanche Naco" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label styleClass="form-label" text="Calle" GridPane.rowIndex="4"/>
                                        <TextField fx:id="txtCalle" promptText="Nombre de la calle" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                        <Label styleClass="form-label" text="Número" GridPane.rowIndex="5"/>
                                        <TextField fx:id="txtNumero" promptText="Ej: 123" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                                        <Label styleClass="form-label" text="Referencia" GridPane.rowIndex="6"/>
                                        <TextField fx:id="txtReferencia" promptText="Frente a... / Edf. X" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                                    </children>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>
                                </GridPane>
                            </children>
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" maxWidth="982" spacing="16">
                        <children>
                            <Button fx:id="btnLimpiar" onAction="#fnLimpiar" text="Limpiar" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnVolver" onAction="#fnVolverMenu" text="← Volver" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnGuardar" onAction="#fnGuardarCambios" text="Guardar Cambios" styleClass="btn, btn-primary"/>
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>