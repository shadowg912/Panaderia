<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Facturas_pagadas_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — VENTAS"/>
            <Label styleClass="header-title" text="Facturas Pagadas"/>
            <Label styleClass="text-accent" text="Consulta de facturas pagadas y sus pagos"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">

            <HBox spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-small" text="CLIENTE"/>
                    <ComboBox fx:id="cmbCliente" onAction="#fnClienteSeleccionado"
                              promptText="Todos los clientes" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <TableView fx:id="tblFacturas" prefHeight="300" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colIdFactura" prefWidth="80" text="ID FAC."/>
                    <TableColumn fx:id="colNumFactura" prefWidth="160" text="N° FACTURA"/>
                    <TableColumn fx:id="colCliente" prefWidth="200" text="CLIENTE"/>
                    <TableColumn fx:id="colFecha" prefWidth="110" text="FECHA"/>
                    <TableColumn fx:id="colTotal" prefWidth="130" text="TOTAL (RD$)"/>
                    <TableColumn fx:id="colUltimoPago" prefWidth="130" text="ÚLTIMO PAGO"/>
                    <TableColumn fx:id="colPagado" prefWidth="130" text="TOTAL PAGADO (RD$)"/>
                    <TableColumn fx:id="colAccion" prefWidth="90" text="ACCIÓN"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="No hay facturas pagadas para mostrar"/>
                </placeholder>
            </TableView>

            <TableView fx:id="tblPagos" prefHeight="200" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colPagoId" prefWidth="80" text="ID PAGO"/>
                    <TableColumn fx:id="colPagoMonto" prefWidth="150" text="MONTO (RD$)"/>
                    <TableColumn fx:id="colPagoFecha" prefWidth="180" text="FECHA"/>
                    <TableColumn fx:id="colPagoForma" prefWidth="150" text="FORMA DE PAGO"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="Seleccione una factura para ver sus pagos"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 6 0 0 0;">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 facturas pagadas"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar">
            <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-ghost"/>
        </HBox>
    </bottom>
</BorderPane>
