<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Ver_recetas_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — PRODUCCIÓN"/>
                <Label styleClass="header-title" text="Ver Recetas"/>
                <Label styleClass="text-accent" text="Gestione las recetas de productos terminados"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card">
                <children>
                    <VBox spacing="5">
                        <Label styleClass="label-small" text="BUSCAR PRODUCTO"/>
                        <TextField fx:id="txtBuscar" prefWidth="280" promptText="Nombre del producto..."/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button onAction="#fnBuscar" text="Buscar" styleClass="btn, btn-primary"/>
                </children>
            </HBox>

            <TableView fx:id="tablaRecetas" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="70" text="ID"/>
                    <TableColumn fx:id="colProducto" prefWidth="350" text="PRODUCTO"/>
                    <TableColumn fx:id="colIngredientes" prefWidth="120" text="INGREDIENTES"/>
                    <TableColumn fx:id="colAccion" prefWidth="250" text="ACCIONES"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0 0 0;">
                <children>
                    <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 recetas"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#fnVolverMenu" text="← Volver" styleClass="btn, btn-secondary"/>
                </children>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>