<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Confirmar_orden_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — VENTAS"/>
                <Label styleClass="header-title" text="Confirmar Orden de Venta"/>
                <Label fx:id="lblInfoOrden" styleClass="text-accent" text="Cliente: [Nombre] · Forma de Pago: [Forma]"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 40;">
            <children>
                <VBox spacing="16" styleClass="card">
                    <children>
                        <Label styleClass="card-title" text="Detalles de la Orden"/>
                        <TableView fx:id="tblProductos" prefHeight="240" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colProducto" prefWidth="360" minWidth="200" text="Producto"/>
                                <TableColumn fx:id="colCantidad" prefWidth="100" minWidth="80" text="Cant." style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="colPrecio" prefWidth="140" minWidth="100" text="P.U. (RD$)" style="-fx-alignment: CENTER_RIGHT;"/>
                                <TableColumn fx:id="colTotal" prefWidth="140" minWidth="100" text="Total (RD$)" style="-fx-alignment: CENTER_RIGHT;"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <VBox spacing="12" styleClass="card" style="-fx-min-width: 380; -fx-padding: 24 40;">
                            <children>
                                <HBox>
                                    <Label styleClass="form-label" text="Subtotal:" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblSubtotal" styleClass="text-body" style="-fx-font-weight: bold;" text="RD$ 0.00"/>
                                </HBox>
                                <HBox>
                                    <Label styleClass="form-label" text="ITBIS (18%):" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblItbis" styleClass="text-body" style="-fx-font-weight: bold;" text="RD$ 0.00"/>
                                </HBox>
                                <Separator styleClass="separator-dark"/>
                                <HBox>
                                    <Label styleClass="card-title" text="TOTAL:" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotal" styleClass="card-title" text="RD$ 0.00"/>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="16">
                    <children>
                        <Button fx:id="btnEditar" onAction="#fnEditarOrden" text="Editar Orden" styleClass="btn, btn-secondary"/>
                        <Button fx:id="btnCancelar" onAction="#fnCancelarOrden" text="Cancelar Orden" styleClass="btn, btn-secondary"/>
                        <Button fx:id="btnEmitir" onAction="#fnEmitirOrden" text="Emitir Orden" styleClass="btn, btn-primary"/>
                        <Button fx:id="btnvolvermenu" onAction="#fnVolvermenu" text="Volver al menu" styleClass="btn, btn-primary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="footer-bar" style="-fx-padding: 12 24;">
            <children>
                <Label styleClass="text-placeholder" text="Confirmación de Orden de Venta"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>