<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane fx:controller="controllers.Orden_venta_controller" prefHeight="720" prefWidth="1280"
            style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox style="-fx-background-color: #1e293b; -fx-padding: 16 24; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #38bdf8; -fx-letter-spacing: 2;" text="PANADERÍA — VENTAS"/>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;" text="Nueva Orden de Venta"/>
                <Label style="-fx-font-size: 13px; -fx-text-fill: #38bdf8;" text="Cliente: [Nombre del cliente seleccionado]"/>
            </children>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.42" prefHeight="600" style="-fx-background-color: #0f172a; -fx-border-color: transparent;">
            <items>
                <!-- Panel izquierdo: Búsqueda de productos -->
                <VBox spacing="14" style="-fx-padding: 24; -fx-background-color: #0f172a;">
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" text="Buscar Producto"/>
                        <HBox spacing="10">
                            <children>
                                <TextField promptText="Código o nombre..." HBox.hgrow="ALWAYS" style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #334155; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 9;"/>
                                <Button style="-fx-background-color: #6366f1; -fx-text-fill: #fff3eb; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 9 18;" text="Buscar"/>
                            </children>
                        </HBox>
                        <TableView prefHeight="400" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <columns>
                                <TableColumn prefWidth="90" text="Código"/>
                                <TableColumn prefWidth="200" text="Producto"/>
                                <TableColumn prefWidth="120" text="Precio (RD$)"/>
                                <TableColumn prefWidth="70" text="Stock"/>
                                <TableColumn prefWidth="70" text="Acción"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
                <!-- Panel derecho: Carrito / Resumen -->
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #0f172a;">
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" text="Productos Seleccionados"/>
                        <TableView prefHeight="240" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <columns>
                                <TableColumn prefWidth="180" text="Producto"/>
                                <TableColumn prefWidth="70" text="Cant."/>
                                <TableColumn prefWidth="110" text="P.U. (RD$)"/>
                                <TableColumn prefWidth="110" text="Total (RD$)"/>
                                <TableColumn prefWidth="70" text="Eliminar"/>
                            </columns>
                        </TableView>
                        <!-- Resumen fiscal -->
                        <VBox spacing="10" style="-fx-background-color: #1e293b; -fx-padding: 20; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <children>
                                <HBox>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px;" text="Subtotal:" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-font-weight: bold;" text="RD$ 1,250.00"/>
                                </HBox>
                                <HBox>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px;" text="ITBIS (18%):" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-font-weight: bold;" text="RD$ 225.00"/>
                                </HBox>
                                <Separator style="-fx-background-color: #334155;"/>
                                <HBox>
                                    <Label style="-fx-text-fill: #38bdf8; -fx-font-size: 17px; -fx-font-weight: bold;" text="Total:" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #38bdf8; -fx-font-size: 17px; -fx-font-weight: bold;" text="RD$ 1,475.00"/>
                                </HBox>
                            </children>
                        </VBox>
                        <!-- Botones -->
                        <HBox alignment="CENTER_RIGHT" spacing="14">
                            <children>
                                <Button style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 24;" text="Cancelar Orden"/>
                                <Button style="-fx-background-color: #6366f1; -fx-text-fill: #fff3eb; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 11 24;" text="Confirmar Orden"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #1e293b; -fx-padding: 12; -fx-border-color: #334155; -fx-border-width: 1 0 0 0;"/>
    </bottom>
</BorderPane>