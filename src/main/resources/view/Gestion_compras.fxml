<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Gestion_compras_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — COMPRAS"/>
            <Label styleClass="header-title" text="Gestión de Compras"/>
            <Label styleClass="text-accent" text="Administrar compras a proveedores y registro de stock"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5">
                    <Label styleClass="label-small" text="FILTRAR ESTADO"/>
                    <ComboBox fx:id="cmbFiltroEstado" onAction="#fnFiltrar" prefWidth="180" promptText="Todos los estados"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="label-small" text="PROVEEDOR"/>
                    <ComboBox fx:id="cmbFiltroProveedor" onAction="#fnFiltrar" prefWidth="220" promptText="Todos los proveedores"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#fnEntregar" fx:id="btnEntregar" text="Marcar como Entregada" styleClass="btn, btn-primary"/>
                <Button onAction="#fnCancelar" fx:id="btnCancelar" text="Cancelar Compra" styleClass="btn, btn-secondary"/>
                <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
            </HBox>

            <TableView fx:id="tablaCompras" prefHeight="500" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                    <TableColumn fx:id="colProveedor" prefWidth="200" text="PROVEEDOR"/>
                    <TableColumn fx:id="colFecha" prefWidth="130" text="FECHA"/>
                    <TableColumn fx:id="colFormaPago" prefWidth="140" text="FORMA PAGO"/>
                    <TableColumn fx:id="colMonto" prefWidth="140" text="MONTO TOTAL"/>
                    <TableColumn fx:id="colEstado" prefWidth="130" text="ESTADO"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 6 0 0 0;">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 compras"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
