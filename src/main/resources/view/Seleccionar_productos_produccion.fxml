<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Seleccionar_productos_produccion_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — PRODUCCIÓN"/>
                <Label styleClass="header-title" text="Agregar Productos a Producir"/>
                <Label fx:id="lblInfo" styleClass="text-accent"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox spacing="16" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-small" text="PRODUCTO"/>
                    <ComboBox fx:id="cmbProducto" prefWidth="350" promptText="Seleccionar producto..."/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="label-small" text="CANTIDAD"/>
                    <Spinner fx:id="spCantidad" prefWidth="120" editable="true"/>
                </VBox>
                <VBox spacing="5">
                    <Label style="-fx-text-fill: transparent;" text="."/>
                    <Button onAction="#fnAgregar" text="+ Agregar" styleClass="btn, btn-primary"/>
                </VBox>
            </HBox>

            <TableView fx:id="tablaProductos" prefHeight="380" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colProducto" prefWidth="350" text="PRODUCTO"/>
                    <TableColumn fx:id="colCantidad" prefWidth="150" text="CANTIDAD"/>
                    <TableColumn fx:id="colAccion" prefWidth="100" text="ACCIÓN"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 6 0 0 0;">
                <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 productos"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Volver" onAction="#fnVolver" styleClass="btn, btn-secondary"/>
                <Button text="Finalizar Orden" onAction="#fnFinalizar" styleClass="btn, btn-primary"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
