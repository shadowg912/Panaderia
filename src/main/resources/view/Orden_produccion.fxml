<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Orden_produccion_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — PRODUCCIÓN"/>
                <Label styleClass="header-title" text="Nueva Orden de Producción"/>
                <Label styleClass="header-subtitle" text="Gestión de lotes de fabricación y asignación de personal"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="bg-main">
            <content>
                <VBox spacing="32" style="-fx-padding: 40;">
                    <children>
                        <VBox spacing="20">
                            <children>
                                <Label styleClass="card-title" text="DETALLES DE LA ORDEN"/>

                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="50"/>
                                        <ColumnConstraints percentWidth="50"/>
                                    </columnConstraints>

                                    <children>
                                        <VBox spacing="8" GridPane.columnIndex="0">
                                            <Label styleClass="form-label" text="Producto a Fabricar *"/>
                                            <ComboBox fx:id="cmbProducto" maxWidth="Infinity" promptText="Seleccionar producto..."/>
                                        </VBox>

                                        <VBox spacing="8" GridPane.columnIndex="1">
                                            <Label styleClass="form-label" text="Empleado Responsable *"/>
                                            <HBox spacing="12">
                                                <children>
                                                    <VBox spacing="5" prefWidth="100">
                                                        <children>
                                                            <Label styleClass="label-small" text="ID"/>
                                                            <TextField fx:id="txtIdEmpleado" promptText="ID"/>
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <Label styleClass="label-small" text="NOMBRE"/>
                                                            <TextField fx:id="txtNombreEmpleado" editable="false" styleClass="text-readonly"/>
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5">
                                                        <children>
                                                            <Label style="-fx-text-fill: transparent;" text="."/>
                                                            <Button fx:id="btnBuscarEmpleado" onAction="#fnBuscarEmpleado" text="Buscar" styleClass="btn, btn-secondary"/>
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>
                                        </VBox>

                                        <VBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="0">
                                            <Label styleClass="form-label" text="Cantidad Planificada *"/>
                                            <TextField fx:id="txtCantidad" promptText="0.00"/>
                                        </VBox>

                                        <VBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <Label styleClass="form-label" text="Estado Inicial"/>
                                            <ComboBox fx:id="cmbEstado" maxWidth="Infinity" promptText="Seleccionar estado..."/>
                                        </VBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <children>
                                <Button fx:id="btnLimpiar" onAction="#fnLimpiar" text="Limpiar" styleClass="btn, btn-secondary"/>
                                <Button fx:id="btnCancelar" onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
                                <Button fx:id="btnGuardar" onAction="#fnGuardarOrden" text="Generar Orden" styleClass="btn, btn-primary"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>