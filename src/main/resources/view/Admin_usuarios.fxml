<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Admin_usuarios_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — ADMINISTRACIÓN"/>
                <Label styleClass="header-title" text="Administración de Usuarios"/>
                <Label styleClass="text-accent" text="Gestione los usuarios del sistema"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card">
                <children>
                    <VBox spacing="5">
                        <Label styleClass="label-small" text="BUSCAR EMPLEADO"/>
                        <TextField fx:id="txtBuscar" prefWidth="280" promptText="Nombre del empleado..."/>
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="label-small" text="ESTADO"/>
                        <ComboBox fx:id="cmbEstado" prefWidth="150" promptText="Todos"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button onAction="#fnBuscar" text="Buscar" styleClass="btn, btn-primary"/>
                </children>
            </HBox>

            <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="80" text="ID"/>
                    <TableColumn fx:id="colUsuario" prefWidth="180" text="USUARIO"/>
                    <TableColumn fx:id="colEmpleado" prefWidth="250" text="EMPLEADO"/>
                    <TableColumn fx:id="colRol" prefWidth="150" text="ROL"/>
                    <TableColumn fx:id="colEstado" prefWidth="120" text="ESTADO"/>
                    <TableColumn fx:id="colAccion" prefWidth="150" text="ACCIONES"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 10 0 0 0;">
                <children>
                    <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 usuarios"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#fnVolverMenu" text="← Volver" styleClass="btn, btn-secondary"/>
                </children>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>