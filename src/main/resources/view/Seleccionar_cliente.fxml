<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <!-- Header -->
    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                            <image>
                                <Image url="@../assets/logo_panaderia.png" />
                            </image>
                        </ImageView>
                        <VBox>
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Panadería" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <!-- Center -->
    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
            <children>
                <Label style="-fx-font-size: 28px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Seleccionar Cliente" />

                <!-- Buscador -->
                <HBox alignment="CENTER" spacing="12">
                    <children>
                        <TextField promptText="Buscar por RNC, nombre o teléfono..." style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 10; -fx-font-size: 16;" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 10 24; -fx-font-size: 16;" text="Buscar" />
                    </children>
                </HBox>

                <!-- Tabla de clientes -->
                <TableView prefHeight="300" prefWidth="900" style="-fx-border-color: #3b2b1c; -fx-border-width: 1;">
                    <columns>
                        <TableColumn prefWidth="150" text="RNC" />
                        <TableColumn prefWidth="300" text="Nombre" />
                        <TableColumn prefWidth="150" text="Teléfono" />
                        <TableColumn prefWidth="250" text="Email" />
                        <TableColumn prefWidth="100" text="Tipo" />
                    </columns>
                </TableView>

                <!-- Botones de acción -->
                <HBox alignment="CENTER" spacing="16">
                    <children>
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 32; -fx-font-size: 16;" text="Nuevo Cliente" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 32; -fx-font-size: 16;" text="Seleccionar" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 12;" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
