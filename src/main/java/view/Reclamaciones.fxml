<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Reclamaciones de Venta" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.5" prefHeight="600">
            <items>
                <!-- Panel izquierdo: Lista de reclamaciones -->
                <VBox spacing="16" style="-fx-padding: 20;">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c;" text="Reclamaciones Recientes" />

                        <TableView prefHeight="350" style="-fx-border-color: #3b2b1c; -fx-border-width: 1;">
                            <columns>
                                <TableColumn prefWidth="120" text="Nº Reclamo" />
                                <TableColumn prefWidth="100" text="Factura" />
                                <TableColumn prefWidth="120" text="Fecha" />
                                <TableColumn prefWidth="100" text="Estado" />
                                <TableColumn prefWidth="100" text="Prioridad" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER" spacing="10">
                            <children>
                                <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 10 20;" text="Nuevo Reclamo" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Panel derecho: Detalle de reclamo -->
                <VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f3dbb3;">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Detalle de Reclamo" />

                        <GridPane hgap="16" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="120" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>

                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="Nº Reclamo:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="RCL-2026-042" GridPane.columnIndex="1" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Factura:" GridPane.rowIndex="1" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="FV-2026-0087" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Cliente:" GridPane.rowIndex="2" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="Supermercados del Caribe SRL" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Fecha:" GridPane.rowIndex="3" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="16/02/2026" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Estado:" GridPane.rowIndex="4" />
                                <ComboBox style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                    <items>

                                    </items>
                                </ComboBox>

                                <Label style="-fx-text-fill: #3b2b1c;" text="Prioridad:" GridPane.rowIndex="5" />
                                <ComboBox style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                    <items>

                                    </items>

                                </ComboBox>
                            </children>
                        </GridPane>

                        <Label style="-fx-text-fill: #3b2b1c;" text="Descripción del problema:" />
                        <TextArea prefHeight="120" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" />

                        <Label style="-fx-text-fill: #3b2b1c;" text="Solución propuesta:" />
                        <TextArea prefHeight="120" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" />

                        <HBox alignment="CENTER" spacing="16">
                            <children>
                                <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 28; -fx-font-size: 16;" text="Guardar Cambios" />
                                <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 28; -fx-font-size: 16;" text="Cancelar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
