<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Dirección de Entrega" />
                    </children>
                </HBox>
                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c;" text="Cliente: [Nombre del cliente]" />
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
            <children>
                <!-- Opción 1: Usar dirección guardada -->
                <TitledPane style="-fx-border-color: #3b2b1c; -fx-border-width: 1;" text="Direcciones Guardadas">
                    <content>
                        <VBox spacing="12">
                            <children>
                                <RadioButton selected="true" text="Calle Principal #123, Zona Colonial, Santo Domingo" />
                                <RadioButton text="Av. Independencia #456, Ensanche Naco, Santo Domingo" />
                                <RadioButton text="Calle Duarte #789, Los Alcarrizos" />
                            </children>
                        </VBox>
                    </content>
                </TitledPane>

                <!-- Opción 2: Nueva dirección -->
                <TitledPane style="-fx-border-color: #3b2b1c; -fx-border-width: 1;" text="Nueva Dirección">
                    <content>
                        <GridPane hgap="16" style="-fx-padding: 16;" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="120" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>

                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="Calle:" />
                                <TextField style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" GridPane.columnIndex="1" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Número:" GridPane.rowIndex="1" />
                                <TextField style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Ciudad:" GridPane.rowIndex="2" />
                                <TextField style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="Provincia:" GridPane.rowIndex="3" />
                                <ComboBox style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label style="-fx-text-fill: #3b2b1c;" text="País:" GridPane.rowIndex="4" />
                                <TextField editable="false" style="-fx-background-color: #f3e9df; -fx-border-color: #3b2b1c; -fx-border-width: 1;" text="República Dominicana" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                        </GridPane>
                    </content>
                </TitledPane>

                <!-- Costo de envío -->
                <HBox alignment="CENTER" spacing="16">
                    <children>
                        <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 16px;" text="Costo de Envío:" />
                        <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 16px; -fx-font-weight: bold;" text="RD$ 150.00" />
                    </children>
                </HBox>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="16">
                    <children>
                        <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 28; -fx-font-size: 16;" text="Volver" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 28; -fx-font-size: 16;" text="Continuar" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 12;" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
