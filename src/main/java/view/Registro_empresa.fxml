<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Registro de Cliente Empresarial" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane style="-fx-background-color: #f3e9df;">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
                    <!-- Panel principal con dos columnas -->
                    <HBox alignment="TOP_CENTER" spacing="32">
                        <!-- Columna izquierda: Datos de la empresa -->
                        <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-min-width: 500;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold; -fx-underline: true;" text="Datos de la Empresa" />

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                    </rowConstraints>

                                    <children>
                                        <Label style="-fx-text-fill: #3b2b1c;" text="RNC *" GridPane.rowIndex="0" />
                                        <TextField promptText="Ej: 123-456789-0" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Nombre Empresa *" GridPane.rowIndex="1" />
                                        <TextField promptText="Ej: Supermercados del Caribe SRL" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Teléfono *" GridPane.rowIndex="2" />
                                        <TextField promptText="(809) 555-1234" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Email *" GridPane.rowIndex="3" />
                                        <TextField promptText="ventas@empresa.com" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label style="-fx-text-fill: #3b2b1c;" GridPane.rowIndex="4" />

                                        <Label style="-fx-text-fill: #3b2b1c;" GridPane.rowIndex="5" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Columna derecha: Dirección y contacto -->
                        <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-min-width: 450;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold; -fx-underline: true;" text="Dirección Fiscal" />

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="120" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints /><RowConstraints />
                                    </rowConstraints>

                                    <children>
                                        <Label style="-fx-text-fill: #3b2b1c;" text="Calle *" GridPane.rowIndex="0" />
                                        <TextField promptText="Calle Principal" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Número *" GridPane.rowIndex="1" />
                                        <TextField promptText="123" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Sector/Barrio" GridPane.rowIndex="2" />
                                        <TextField promptText="Zona Colonial" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Ciudad *" GridPane.rowIndex="3" />
                                        <TextField promptText="Santo Domingo" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Provincia *" GridPane.rowIndex="4" />
                                        <ComboBox promptText="Seleccione provincia" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 6;" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                            <items>
                                            </items>
                                        </ComboBox>

                                        <Label style="-fx-text-fill: #3b2b1c;" text="País *" GridPane.rowIndex="5" />
                                        <TextField editable="false" style="-fx-background-color: #f3e9df; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" text="República Dominicana" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </HBox>

                    <!-- Botones de acción -->
                    <HBox alignment="CENTER" spacing="24">
                        <children>
                            <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 32; -fx-font-size: 16;" text="Limpiar Formulario" />
                            <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 32; -fx-font-size: 16;" text="Cancelar" />
                            <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 32; -fx-font-size: 16; -fx-font-weight: bold;" text="Guardar Cliente" />
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;" />
    </bottom>
</BorderPane>
