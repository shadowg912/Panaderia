<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox style="-fx-background-color: #1e293b; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-text-fill: #f1f5f9; -fx-font-weight: bold;" text="Registro de empresa" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #f1f5f9;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <ScrollPane style="-fx-background-color: #0f172a; -fx-background: #0f172a;">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32; -fx-background-color: #0f172a;">
                    <!-- Panel principal con dos columnas -->
                    <HBox alignment="TOP_CENTER" spacing="32">
                        <!-- Columna izquierda: Datos de la empresa -->
                        <VBox spacing="16" style="-fx-background-color: #1e293b; -fx-padding: 24; -fx-border-color: #334155; -fx-border-width: 1; -fx-min-width: 500;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-underline: true;" text="Datos de la Empresa" />
                                <GridPane hgap="16" vgap="12">
                                </GridPane>
                            </children>
                        </VBox>
                        <!-- Columna derecha: Dirección y contacto -->
                        <VBox spacing="16" style="-fx-background-color: #1e293b; -fx-padding: 24; -fx-border-color: #334155; -fx-border-width: 1; -fx-min-width: 450;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-underline: true;" text="Dirección Fiscal" />
                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="120" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                        <RowConstraints />
                                    </rowConstraints>
                                    <children>
                                        <Label style="-fx-text-fill: #f1f5f9;" text="Calle *" GridPane.rowIndex="0" />
                                        <TextField promptText="Calle Principal" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-padding: 8; -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #334155;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label style="-fx-text-fill: #f1f5f9;" text="Número *" GridPane.rowIndex="1" />
                                        <TextField promptText="123" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-padding: 8; -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #334155;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label style="-fx-text-fill: #f1f5f9;" text="Sector/Barrio" GridPane.rowIndex="2" />
                                        <TextField promptText="Zona Colonial" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-padding: 8; -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #334155;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label style="-fx-text-fill: #f1f5f9;" text="Ciudad *" GridPane.rowIndex="3" />
                                        <TextField promptText="Santo Domingo" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-padding: 8; -fx-text-fill: #f1f5f9; -fx-prompt-text-fill: #334155;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label style="-fx-text-fill: #f1f5f9;" text="Provincia *" GridPane.rowIndex="4" />
                                        <ComboBox promptText="Seleccione provincia" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-padding: 6; -fx-text-fill: #f1f5f9;" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                            <items> </items>
                                        </ComboBox>
                                        <Label style="-fx-text-fill: #f1f5f9;" text="País *" GridPane.rowIndex="5" />
                                        <TextField editable="false" style="-fx-background-color: #334155; -fx-border-color: #334155; -fx-border-width: 1; -fx-padding: 8; -fx-text-fill: #f1f5f9;" text="República Dominicana" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </HBox>
                    <!-- Botones de acción -->
                    <HBox alignment="CENTER" spacing="24">
                        <children>
                            <Button style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-padding: 12 32; -fx-font-size: 16; -fx-border-color: #334155; -fx-border-width: 1;" text="Limpiar Formulario" />
                            <Button style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-padding: 12 32; -fx-font-size: 16; -fx-border-color: #334155; -fx-border-width: 1;" text="Cancelar" />
                            <Button style="-fx-background-color: #6366f1; -fx-text-fill: #fff3eb; -fx-padding: 12 32; -fx-font-size: 16; -fx-font-weight: bold;" text="Guardar Cliente" />
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #1e293b; -fx-padding: 12;" />
    </bottom>
</BorderPane>
