<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Seguimiento de Envío" />
                    </children>
                </HBox>
                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c;" text="Factura: FV-2026-0087 | Cliente: Supermercados del Caribe SRL" />
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
            <children>
                <!-- Estado actual -->
                <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #3b2b1c; -fx-border-width: 1;">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Estado del Envío" />

                        <HBox alignment="CENTER" spacing="20">
                            <children>
                                <VBox spacing="8" style="-fx-min-width: 200;">
                                    <children>
                                        <Label style="-fx-text-fill: #b2946f; -fx-font-size: 20px; -fx-font-weight: bold;" text="PENDIENTE" />
                                        <Label style="-fx-text-fill: #3b2b1c;" text="Preparación en bodega" />
                                    </children>
                                </VBox>
                                <VBox spacing="8" style="-fx-min-width: 200;">
                                    <children>
                                        <Label style="-fx-text-fill: #e2d2c2; -fx-font-size: 20px;" text="EN CAMINO" />
                                        <Label style="-fx-text-fill: #3b2b1c;" text="En reparto (no iniciado)" />
                                    </children>
                                </VBox>
                                <VBox spacing="8" style="-fx-min-width: 200;">
                                    <children>
                                        <Label style="-fx-text-fill: #e2d2c2; -fx-font-size: 20px;" text="ENTREGADO" />
                                        <Label style="-fx-text-fill: #3b2b1c;" text="Pendiente de confirmación" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="16">
                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="Fecha estimada de entrega:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="18/02/2026" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER" spacing="16">
                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="Costo de envío:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="RD$ 150.00" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Historial de estado -->
                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 16; -fx-border-color: #3b2b1c; -fx-border-width: 1;">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Historial de Estados" />
                        <ListView prefHeight="120">

                        </ListView>
                    </children>
                </VBox>

                <!-- Acciones -->
                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 28; -fx-font-size: 16;" text="Actualizar Estado" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 28; -fx-font-size: 16;" text="Imprimir Guía de Envío" />
                        <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 28; -fx-font-size: 16;" text="Volver" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;" />
    </bottom>
</BorderPane>
