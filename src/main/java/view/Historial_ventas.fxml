<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Historial de Ventas" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
            <children>
                <!-- Filtros -->
                <HBox alignment="CENTER" spacing="16">
                    <children>
                        <ComboBox promptText="Cliente" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" />
                        <DatePicker promptText="Fecha inicio" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" />
                        <DatePicker promptText="Fecha fin" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1;" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 8 20; -fx-font-size: 14;" text="Buscar" />
                    </children>
                </HBox>

                <!-- Tabla de ventas -->
                <TableView prefHeight="400" prefWidth="1100" style="-fx-border-color: #3b2b1c; -fx-border-width: 1;">
                    <columns>
                        <TableColumn prefWidth="120" text="Nº Factura" />
                        <TableColumn prefWidth="120" text="Fecha" />
                        <TableColumn prefWidth="250" text="Cliente" />
                        <TableColumn prefWidth="120" text="Total (RD$)" />
                        <TableColumn prefWidth="100" text="Estado" />
                        <TableColumn prefWidth="100" text="Orden" />
                        <TableColumn prefWidth="120" text="Acciones" />
                    </columns>
                </TableView>

                <!-- Paginación -->
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 8 16;" text="Anterior" />
                        <Label style="-fx-text-fill: #3b2b1c;" text="Página 1 de 5" />
                        <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 8 16;" text="Siguiente" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;" />
    </bottom>
</BorderPane>
