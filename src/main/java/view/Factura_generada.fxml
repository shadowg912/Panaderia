<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                            <image>
                                <Image url="@../assets/logo_panaderia.png" />
                            </image>
                        </ImageView>
                        <VBox>
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Factura de Venta" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c;" text="Nº FV-2026-0087 | Emitida el 16/02/2026" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
            <children>
                <!-- Encabezado de factura -->
                <HBox alignment="TOP_LEFT" spacing="40">
                    <children>
                        <VBox spacing="8" style="-fx-min-width: 300;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Panadería" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="RNC: 123-456789-0" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="Calle Principal #123, Zona Colonial" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="Santo Domingo, República Dominicana" />
                            </children>
                        </VBox>
                        <VBox spacing="8" style="-fx-min-width: 300;">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Cliente:" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="Supermercados del Caribe SRL" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="RNC: 987-654321-0" />
                                <Label style="-fx-text-fill: #3b2b1c;" text="Av. Independencia #456, Ensanche Naco" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Líneas de producto -->
                <TableView prefHeight="250" prefWidth="900" style="-fx-border-color: #3b2b1c; -fx-border-width: 1;">
                    <columns>
                        <TableColumn prefWidth="350" text="Descripción" />
                        <TableColumn prefWidth="80" text="Cant." />
                        <TableColumn prefWidth="120" text="P.U. (RD$)" />
                        <TableColumn prefWidth="80" text="Desc." />
                        <TableColumn prefWidth="120" text="Total (RD$)" />
                        <TableColumn prefWidth="80" text="IVA" />
                    </columns>
                </TableView>

                <!-- Resumen fiscal -->
                <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 16; -fx-border-color: #3b2b1c; -fx-border-width: 1;">
                    <children>
                        <HBox spacing="16">
                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="Base Imponible:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="RD$ 1,250.00" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <HBox spacing="16">
                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="ITBIS 18%:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="RD$ 225.00" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <HBox spacing="16">
                            <children>
                                <Label style="-fx-text-fill: #3b2b1c;" text="Envío:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="RD$ 150.00" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <HBox spacing="16" style="-fx-border-top: 2px solid #3b2b1c; -fx-padding-top: 8;">
                            <children>
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 18px; -fx-font-weight: bold;" text="TOTAL A PAGAR:" />
                                <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 18px; -fx-font-weight: bold;" text="RD$ 1,625.00" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Estado y acciones -->
                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Label style="-fx-text-fill: #3b2b1c; -fx-font-size: 16px; -fx-font-weight: bold;" text="Estado: Emitida" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 28; -fx-font-size: 16;" text="Imprimir Factura" />
                        <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 28; -fx-font-size: 16;" text="Registrar Pago" />
                        <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 28; -fx-font-size: 16;" text="Volver al Inicio" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;" />
    </bottom>
</BorderPane>
