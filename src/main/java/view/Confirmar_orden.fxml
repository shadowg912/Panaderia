<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #0f172a;">
    <top>
        <VBox style="-fx-background-color: #1e293b; -fx-padding: 16 24; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #38bdf8; -fx-letter-spacing: 2;" text="PANADERÍA — VENTAS · PASO 4 DE 4"/>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f1f5f9;" text="Confirmar Orden de Venta"/>
                <Label style="-fx-font-size: 13px; -fx-text-fill: #38bdf8;" text="Cliente: [Nombre del cliente] · Dirección: [Dirección formateada]"/>
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 32; -fx-background-color: #0f172a;">
            <children>
                <!-- Tabla de productos -->
                <VBox spacing="12" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 22 24;">
                    <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #38bdf8; -fx-padding: 0 0 4 0;" text="Detalles de la Orden"/>
                        <TableView prefHeight="220" style="-fx-background-color: #0f172a; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <columns>
                                <TableColumn prefWidth="340" text="Producto"/>
                                <TableColumn prefWidth="90" text="Cant."/>
                                <TableColumn prefWidth="130" text="P.U. (RD$)"/>
                                <TableColumn prefWidth="130" text="Total (RD$)"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
                <!-- Resumen de totales -->
                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <VBox spacing="10" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 22 32; -fx-min-width: 340;">
                            <children>
                                <HBox>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px;" text="Subtotal:" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-font-weight: bold;" text="RD$ 1,250.00"/>
                                </HBox>
                                <HBox>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px;" text="IVA (18%):" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-font-weight: bold;" text="RD$ 225.00"/>
                                </HBox>
                                <HBox>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px;" text="Envío:" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-font-weight: bold;" text="RD$ 150.00"/>
                                </HBox>
                                <Separator style="-fx-background-color: #334155;"/>
                                <HBox>
                                    <Label style="-fx-text-fill: #38bdf8; -fx-font-size: 18px; -fx-font-weight: bold;" text="TOTAL FINAL:" HBox.hgrow="ALWAYS"/>
                                    <Label style="-fx-text-fill: #38bdf8; -fx-font-size: 18px; -fx-font-weight: bold;" text="RD$ 1,625.00"/>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <!-- Botones -->
                <HBox alignment="CENTER_RIGHT" spacing="14">
                    <children>
                        <Button style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 26;" text="Editar Orden"/>
                        <Button style="-fx-background-color: #1e293b; -fx-text-fill: #f1f5f9; -fx-font-size: 14px; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 26;" text="Cancelar Orden"/>
                        <Button style="-fx-background-color: #6366f1; -fx-text-fill: #fff3eb; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 11 26;" text="Emitir Orden"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-background-color: #1e293b; -fx-padding: 12 24; -fx-border-color: #334155; -fx-border-width: 1 0 0 0;">
            <children>
                <Label style="-fx-text-fill: #334155; -fx-font-size: 12px;" text="Orden de Venta — Paso 4 / 4"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>