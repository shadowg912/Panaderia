<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #f3e9df;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #f3dbb3; -fx-padding: 12;">
            <children>
                <HBox spacing="16">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-font-size: 24px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold;" text="Registro de Producto" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #3b2b1c;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane style="-fx-background-color: #f3e9df;">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32; -fx-background-color: #f3e9df;">
                    <!-- Panel principal con dos columnas -->
                    <HBox alignment="TOP_CENTER" spacing="32">
                        <!-- Columna izquierda: Datos básicos -->
                        <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-min-width: 500;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold; -fx-underline: true;" text="Datos del Producto" />

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                    </rowConstraints>

                                    <children>
                                        <Label style="-fx-text-fill: #3b2b1c;" text="Código *" GridPane.rowIndex="0" />
                                        <TextField promptText="Ej:001" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Nombre *" GridPane.rowIndex="1" />
                                        <TextField promptText="Ej: Pan Francés" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Unidad *" GridPane.rowIndex="2" />
                                        <ComboBox promptText="Seleccione unidad" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 6;" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <items>

                                            </items>
                                        </ComboBox>

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Precio Unitario (RD$) *" GridPane.rowIndex="3" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Categoría" GridPane.rowIndex="5" />
                                        <ComboBox promptText="Seleccione categoría" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 6;" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                            <items>

                                            </items>
                                        </ComboBox>

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Tipo" GridPane.rowIndex="6" />
                                        <HBox spacing="16" GridPane.columnIndex="1" GridPane.rowIndex="6">
                                            <children>
                                                <CheckBox style="-fx-text-fill: #3b2b1c;" text="Materia Prima" />
                                                <CheckBox selected="true" style="-fx-text-fill: #3b2b1c;" text="Producto Terminado" />
                                            </children>
                                        </HBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Columna derecha: Valores nutricionales -->
                        <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-min-width: 450;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-text-fill: #3b2b1c; -fx-font-weight: bold; -fx-underline: true;" text="Valores Nutricionales (por 100g)" />

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints />
                                    </rowConstraints>

                                    <children>
                                        <Label style="-fx-text-fill: #3b2b1c;" text="Energía (kcal)" GridPane.rowIndex="0" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Proteínas (g)" GridPane.rowIndex="1" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Carbohidratos (g)" GridPane.rowIndex="2" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Grasas (g)" GridPane.rowIndex="3" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Fibra (g)" GridPane.rowIndex="4" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                        <Label style="-fx-text-fill: #3b2b1c;" text="Sodio (mg)" GridPane.rowIndex="5" />
                                        <TextField promptText="0.00" style="-fx-background-color: white; -fx-border-color: #3b2b1c; -fx-border-width: 1; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                    </children>
                                </GridPane>

                                <HBox spacing="12" style="-fx-background-color: #fff5e8; -fx-border-color: #b2946f; -fx-border-width: 1; -fx-padding: 10; -fx-alignment: CENTER;">
                                    <children>
                                        <Label style="-fx-font-size: 20px;" text="ℹ️" />
                                        <Label maxWidth="350" style="-fx-text-fill: #3b2b1c; -fx-font-size: 13px;" text="Solo aplicable a productos terminados para venta directa" wrapText="true" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </HBox>

                    <!-- Botones de acción -->
                    <HBox alignment="CENTER" spacing="24">
                        <children>
                            <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 32; -fx-font-size: 16;" text="Limpiar Formulario" />
                            <Button style="-fx-background-color: #e2d2c2; -fx-text-fill: #3b2b1c; -fx-padding: 12 32; -fx-font-size: 16;" text="Cancelar" />
                            <Button style="-fx-background-color: #b2946f; -fx-text-fill: #fff5e8; -fx-padding: 12 32; -fx-font-size: 16; -fx-font-weight: bold;" text="Guardar Producto" />
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f3dbb3; -fx-padding: 12;" />
    </bottom>
</BorderPane>
