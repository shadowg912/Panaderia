<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Reclamaciones_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — POSTVENTA"/>
                <Label styleClass="header-title" text="Gestión de Reclamaciones"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox alignment="TOP_CENTER" spacing="32" style="-fx-padding: 40;">
                    <HBox alignment="TOP_CENTER" spacing="32">
                        <VBox spacing="25" styleClass="card" style="-fx-min-width: 520;">
                            <children>
                                <Label styleClass="card-title" text="DATOS DE ORIGEN"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="ID Factura *" GridPane.rowIndex="0"/>
                                        <TextField fx:id="txtIdFactura" promptText="Número de factura" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label styleClass="form-label" text="ID Cliente *" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtIdCliente" promptText="ID de empresa cliente" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label styleClass="form-label" text="ID Empleado" GridPane.rowIndex="2"/>
                                        <TextField fx:id="txtIdEmpleado" promptText="ID del responsable" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="25" styleClass="card" style="-fx-min-width: 520;">
                            <children>
                                <Label styleClass="card-title" text="ESTADO Y PRIORIDAD"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="Tipo *" GridPane.rowIndex="0"/>
                                        <TextField fx:id="txtTipoReclamacion" promptText="Ej: Devolución" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label styleClass="form-label" text="Estado *" GridPane.rowIndex="1"/>
                                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity" prefHeight="50.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="ABIERTA"/>
                                                    <String fx:value="EN_PROCESO"/>
                                                    <String fx:value="RESUELTA"/>
                                                    <String fx:value="CERRADA"/>
                                                </FXCollections>
                                            </items>
                                            <value><String fx:value="ABIERTA"/></value>
                                        </ComboBox>

                                        <Label styleClass="form-label" text="Prioridad *" GridPane.rowIndex="2"/>
                                        <ComboBox fx:id="cmbPrioridad" maxWidth="Infinity" prefHeight="50.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="BAJA"/>
                                                    <String fx:value="MEDIA"/>
                                                    <String fx:value="ALTA"/>
                                                </FXCollections>
                                            </items>
                                            <value><String fx:value="MEDIA"/></value>
                                        </ComboBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </HBox>

                    <VBox maxWidth="1072" spacing="15" styleClass="card">
                        <children>
                            <Label styleClass="card-title" text="MOTIVO DEL RECLAMO"/>
                            <TextArea fx:id="txtMotivo" prefHeight="120" promptText="Describa el problema aquí..." wrapText="true"/>
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" maxWidth="1072" spacing="20">
                        <children>
                            <Button fx:id="btnLimpiar" onAction="#fnLimpiar" text="Limpiar" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnCancelar" onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnGuardar" onAction="#fnGuardarReclamacion" text="Guardar Reclamación" styleClass="btn, btn-primary"/>
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>