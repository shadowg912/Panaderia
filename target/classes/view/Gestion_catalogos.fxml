<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Gestion_catalogos_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — ADMINISTRACIÓN"/>
            <Label styleClass="header-title" text="Gestión de Catálogos"/>
            <Label styleClass="text-accent" text="Administrar tablas de referencia del sistema"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <Label styleClass="label-small" text="CATÁLOGO"/>
                <ComboBox fx:id="cmbCatalogo" onAction="#fnSeleccionarCatalogo" prefWidth="300" promptText="Seleccione un catálogo"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#fnVolver" text="Volver" styleClass="btn, btn-secondary"/>
            </HBox>

            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaCatalogos" prefHeight="400" HBox.hgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                        <TableColumn fx:id="colNombre" prefWidth="250" text="NOMBRE"/>
                        <TableColumn fx:id="colDescripcion" prefWidth="300" text="DESCRIPCIÓN"/>
                        <TableColumn fx:id="colEstado" prefWidth="100" text="ESTADO"/>
                        <TableColumn fx:id="colAccion" prefWidth="120" text="ACCIÓN"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <VBox spacing="16" styleClass="card" prefWidth="360" style="-fx-padding: 20 24;">
                    <Label fx:id="lblTituloForm" styleClass="card-title" text="Nuevo Registro"/>
                    <VBox spacing="8">
                        <Label styleClass="label-small" text="NOMBRE *"/>
                        <TextField fx:id="txtNombre" promptText="Nombre"/>
                    </VBox>
                    <VBox fx:id="panelDescripcion" spacing="8">
                        <Label styleClass="label-small" text="DESCRIPCIÓN"/>
                        <TextArea fx:id="txtDescripcion" promptText="Descripción (opcional)" prefRowCount="3"/>
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 8 0 0 0;">
                        <Button fx:id="btnCancelar" onAction="#fnCancelar" text="Cancelar" styleClass="btn, btn-secondary"/>
                        <Button fx:id="btnGuardar" onAction="#fnGuardar" text="Guardar" styleClass="btn, btn-primary"/>
                    </HBox>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Seleccione un catálogo para comenzar"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
