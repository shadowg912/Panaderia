<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Gestion_proveedores_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — COMPRAS"/>
            <Label styleClass="header-title" text="Administrar Proveedores"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox alignment="TOP_CENTER" spacing="32" style="-fx-padding: 40;">
                    <VBox spacing="16" styleClass="card" style="-fx-min-width: 982; -fx-max-width: 1072;">
                        <Label styleClass="card-title" text="LISTADO DE PROVEEDORES"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <TextField fx:id="txtBuscar" promptText="Buscar por nombre..." prefHeight="42" HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="cmbCategoria" prefHeight="42" prefWidth="220"/>
                            <Button fx:id="btnBuscar" onAction="#fnBuscar" text="Buscar" styleClass="btn, btn-secondary" prefHeight="42"/>
                        </HBox>
                        <TableView fx:id="tablaProveedores" prefHeight="380" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                                <TableColumn fx:id="colNombre" prefWidth="250" text="Nombre"/>
                                <TableColumn fx:id="colTelefono" prefWidth="150" text="Teléfono"/>
                                <TableColumn fx:id="colCorreo" prefWidth="200" text="Correo"/>
                                <TableColumn fx:id="colCategoria" prefWidth="180" text="Categoría"/>
                                <TableColumn fx:id="colAccion" prefWidth="180" text="Acción"/>
                            </columns>
                        </TableView>
                        <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 proveedor(es)"/>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="btnVolver" onAction="#fnVolver" prefHeight="52" text="Volver" styleClass="btn, btn-secondary"/>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
