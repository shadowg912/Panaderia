<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Ver_ordenes_produccion_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — PRODUCCIÓN"/>
                <Label styleClass="header-title" text="Órdenes de Producción"/>
                <Label styleClass="text-accent" text="Gestione y supervise las órdenes de producción"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="24" style="-fx-padding: 32;">

                <VBox spacing="10" styleClass="card">
                    <Label styleClass="card-title" text="ÓRDENES PENDIENTES"/>
                    <TableView fx:id="tablaPendientes" prefHeight="250" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colIdP" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colProductoP" text="PRODUCTO" prefWidth="200"/>
                            <TableColumn fx:id="colEmpleadoP" text="EMPLEADO" prefWidth="200"/>
                            <TableColumn fx:id="colCantidadP" text="CANTIDAD" prefWidth="100"/>
                            <TableColumn fx:id="colFechaP" text="FECHA" prefWidth="120"/>
                            <TableColumn fx:id="colEstadoP" text="ESTADO" prefWidth="100"/>
                            <TableColumn fx:id="colAccionP" text="CAMBIAR" prefWidth="130"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox spacing="10" styleClass="card">
                    <Label styleClass="card-title" text="OTRAS ÓRDENES"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label styleClass="label-small" text="FILTRAR POR ESTADO"/>
                        <ComboBox fx:id="cmbFiltro" prefWidth="140" styleClass="combo-box"/>
                        <Button text="Filtrar" onAction="#fnFiltrar" styleClass="btn, btn-secondary"/>
                    </HBox>
                    <TableView fx:id="tablaOrden" prefHeight="300" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colProducto" text="PRODUCTO" prefWidth="200"/>
                            <TableColumn fx:id="colEmpleado" text="EMPLEADO" prefWidth="200"/>
                            <TableColumn fx:id="colCantidad" text="CANTIDAD" prefWidth="100"/>
                            <TableColumn fx:id="colFecha" text="FECHA" prefWidth="120"/>
                            <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="100"/>
                            <TableColumn fx:id="colAccion" text="CAMBIAR" prefWidth="130"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0 0 0;">
                        <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 órdenes"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="← Volver" onAction="#fnVolver" styleClass="btn, btn-secondary"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>