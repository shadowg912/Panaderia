<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.menu_contoller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="dashboard-header">
            <Label styleClass="dashboard-header-title" text="PANADERÍA"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserName" styleClass="dashboard-header-user"/>
            <Label style="-fx-text-fill: #403d37;" text="|"/>
            <Label fx:id="lblUserRole" styleClass="dashboard-header-user"/>
        </HBox>
    </top>

    <left>
        <BorderPane styleClass="sidebar">
            <top>
                <VBox styleClass="sidebar-header" spacing="4">
                    <Label styleClass="sidebar-logo" text="PANADERÍA"/>
                    <Label style="-fx-text-fill: #c2baab; -fx-font-size: 18px; -fx-font-weight: bold;" text=""/>
                </VBox>
            </top>
            <center>
                <ScrollPane styleClass="sidebar-scroll" fitToWidth="true">
                    <VBox fx:id="sidebarModulos"/>
                </ScrollPane>
            </center>
            <bottom>
                <VBox styleClass="sidebar-footer">
                    <Button fx:id="btnCerrarSesion" onAction="#fnCerrarSesion" maxWidth="Infinity" text="Cerrar Sesión"/>
                </VBox>
            </bottom>
        </BorderPane>
    </left>

    <center>
        <AnchorPane fx:id="contentArea" styleClass="dashboard-content"/>
    </center>

</BorderPane>
