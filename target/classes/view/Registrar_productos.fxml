<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Registro_producto_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — INVENTARIO"/>
                <Label styleClass="header-title" text="Registro de Producto"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
                    <children>
                        <HBox alignment="TOP_CENTER" spacing="28">
                            <!-- Columna izquierda: Datos del Producto -->
                            <VBox spacing="16" styleClass="card" style="-fx-min-width: 500;">
                                <children>
                                    <Label styleClass="card-title" text="Datos del Producto"/>
                                    <GridPane styleClass="form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="160"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>
                                        <rowConstraints>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                        </rowConstraints>
                                        <children>
                                            <Label styleClass="form-label" text="Nombre *" GridPane.rowIndex="1"/>
                                            <TextField fx:id="txtNombre" prefHeight="40.0" prefWidth="291.0" promptText="Ej: Pan Francés" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                            <Label styleClass="form-label" text="Unidad *" GridPane.rowIndex="2"/>
                                            <ComboBox fx:id="cmbUnidad" maxWidth="Infinity" prefHeight="42.0" prefWidth="291.0" promptText="Seleccionar Unidad" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                            <Label styleClass="form-label" text="Precio Unitario (RD$) *" GridPane.rowIndex="3"/>
                                            <TextField fx:id="txtPrecio" prefHeight="38.0" prefWidth="291.0" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                            <Label styleClass="form-label" text="Categoría" GridPane.rowIndex="5"/>
                                            <ComboBox fx:id="cmbCategoria" maxWidth="Infinity" prefHeight="43.0" prefWidth="291.0" promptText="Seleccione categoría" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                            <HBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                                        </children>
                                    </GridPane>
                                </children>
                            </VBox>

                            <!-- Columna derecha: Valores Nutricionales -->
                            <VBox spacing="16" styleClass="card" style="-fx-min-width: 450;">
                                <children>
                                    <Label styleClass="card-title" text="Valores Nutricionales (por 100g)"/>
                                    <GridPane styleClass="form-grid">
                                        <columnConstraints>
                                            <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="150"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>
                                        <rowConstraints>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                            <RowConstraints/>
                                        </rowConstraints>
                                        <children>
                                            <Label styleClass="form-label" text="Energía (kcal)" GridPane.rowIndex="0"/>
                                            <TextField fx:id="txtEnergia" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                            <Label styleClass="form-label" text="Proteínas (g)" GridPane.rowIndex="1"/>
                                            <TextField fx:id="txtProteinas" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                            <Label styleClass="form-label" text="Carbohidratos (g)" GridPane.rowIndex="2"/>
                                            <TextField fx:id="txtCarbohidratos" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                            <Label styleClass="form-label" text="Azúcares (g)" GridPane.rowIndex="3"/>
                                            <TextField fx:id="txtAzucares" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                            <Label styleClass="form-label" text="Grasas totales (g)" GridPane.rowIndex="4"/>
                                            <TextField fx:id="txtGrasas" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                            <Label styleClass="form-label" text="Grasas saturadas (g)" GridPane.rowIndex="5"/>
                                            <TextField fx:id="txtGrasasSaturadas" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                                            <Label styleClass="form-label" text="Grasas trans (g)" GridPane.rowIndex="6"/>
                                            <TextField fx:id="txtGrasasTrans" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                                            <Label styleClass="form-label" text="Fibra (g)" GridPane.rowIndex="7"/>
                                            <TextField fx:id="txtFibra" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                                            <Label styleClass="form-label" text="Sodio (mg)" GridPane.rowIndex="8"/>
                                            <TextField fx:id="txtSodio" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                                        </children>
                                    </GridPane>

                                    <HBox styleClass="info-box">
                                        <children>
                                            <Label style="-fx-font-size: 18px;" text="ℹ️"/>
                                            <Label maxWidth="340" text="Solo aplicable a productos terminados para venta directa" wrapText="true"/>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <children>
                                <Button fx:id="btnlimpiar" onAction="#fnlimpiar" text="Limpiar Formulario" styleClass="btn, btn-secondary"/>
                                <Button fx:id="btnCancelar" onAction="#fnVolerMenu" text="Volver" styleClass="btn, btn-secondary"/>
                                <Button fx:id="btnGuardar" onAction="#fnGuardarProducto" text="Guardar Producto" styleClass="btn, btn-primary"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>