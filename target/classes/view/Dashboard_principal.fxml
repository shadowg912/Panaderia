<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Dashboard_principal_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — SISTEMA DE GESTIÓN"/>
            <Label styleClass="header-title" text="Dashboard Principal"/>
            <Label styleClass="text-accent" text="Resumen general del negocio"/>
        </VBox>
    </top>

    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true">
            <VBox spacing="24" style="-fx-padding: 28 32;">
                <HBox spacing="20">
                    <VBox fx:id="cardVentas" spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 24; -fx-min-width: 0;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #535659; -fx-font-weight: bold;">VENTAS HOY</Label>
                        <Label fx:id="lblVentasHoy" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #100e0a;">RD$ 0.00</Label>
                        <Label fx:id="lblVentasCount" style="-fx-font-size: 12px; -fx-text-fill: #bfb6a6;">0 órdenes</Label>
                    </VBox>
                    <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 24; -fx-min-width: 0;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #535659; -fx-font-weight: bold;">STOCK BAJO</Label>
                        <Label fx:id="lblStockBajo" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #d9534f;">0</Label>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #bfb6a6;">productos con stock &lt; 5</Label>
                    </VBox>
                    <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 24; -fx-min-width: 0;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #535659; -fx-font-weight: bold;">PRODUCCIÓN PENDIENTE</Label>
                        <Label fx:id="lblProdPendiente" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f0ad4e;">0</Label>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #bfb6a6;">órdenes pendientes</Label>
                    </VBox>
                    <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 24; -fx-min-width: 0;">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #535659; -fx-font-weight: bold;">ENVÍOS PENDIENTES</Label>
                        <Label fx:id="lblEnviosPendientes" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #5bc0de;">0</Label>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #bfb6a6;">envíos por entregar</Label>
                    </VBox>
                </HBox>

                <HBox spacing="16" style="-fx-padding: 4 0 0 0;">
                    <VBox alignment="CENTER" spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 16; -fx-cursor: hand;" onMouseClicked="#irAVentas">
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #cdb08e;">V</Label>
                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #535659;">Dashboard Ventas</Label>
                    </VBox>
                    <VBox alignment="CENTER" spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 16; -fx-cursor: hand;" onMouseClicked="#irAInventario">
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #cdb08e;">I</Label>
                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #535659;">Dashboard Inventario</Label>
                    </VBox>
                    <VBox alignment="CENTER" spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 16; -fx-cursor: hand;" onMouseClicked="#irAProduccion">
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #cdb08e;">P</Label>
                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #535659;">Dashboard Producción</Label>
                    </VBox>
                    <VBox alignment="CENTER" spacing="8" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 16; -fx-cursor: hand;" onMouseClicked="#irACompras">
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #cdb08e;">C</Label>
                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #535659;">Dashboard Compras</Label>
                    </VBox>
                </HBox>

                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <VBox spacing="12" styleClass="card" HBox.hgrow="ALWAYS" style="-fx-padding: 20 24;">
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #100e0a;">Productos con Stock Bajo</Label>
                        <TableView fx:id="tablaStockBajo" prefHeight="260" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colProdId" prefWidth="50" text="ID"/>
                                <TableColumn fx:id="colProdNombre" prefWidth="280" text="PRODUCTO"/>
                                <TableColumn fx:id="colProdStock" prefWidth="100" text="STOCK"/>
                                <TableColumn fx:id="colProdTipo" prefWidth="150" text="TIPO"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
