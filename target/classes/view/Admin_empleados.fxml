<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Admin_empleados_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — ADMINISTRACIÓN"/>
                <Label styleClass="header-title" text="Administración de Empleados"/>
                <Label styleClass="text-accent" text="Gestione los empleados del sistema"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card">
                <children>
                    <VBox spacing="5">
                        <Label styleClass="label-small" text="BUSCAR NOMBRE"/>
                        <TextField fx:id="txtBuscar" prefWidth="200" promptText="Nombre o apellido..."/>
                    </VBox>

                    <VBox spacing="5" prefWidth="80">
                        <Label styleClass="label-small" text="ID"/>
                        <TextField fx:id="txtIdEmpleado" promptText="ID"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="label-small" text="PUESTO"/>
                        <ComboBox fx:id="cmbPuesto" prefWidth="180" promptText="Todos los puestos"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button onAction="#fnBuscar" text="Buscar" styleClass="btn, btn-primary"/>
                </children>
            </HBox>

            <TableView fx:id="tablaEmpleados" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="70" text="ID"/>
                    <TableColumn fx:id="colNombre" prefWidth="180" text="NOMBRE"/>
                    <TableColumn fx:id="colApellido1" prefWidth="180" text="APELLIDO1"/>
                    <TableColumn fx:id="colApellido2" prefWidth="150" text="APELLIDO2"/>
                    <TableColumn fx:id="colTelefono" prefWidth="100" text="TELÉFONO"/>
                    <TableColumn fx:id="colPuesto" prefWidth="130" text="PUESTO"/>
                    <TableColumn fx:id="colAccion" prefWidth="200" text="ACCIONES"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0 0 0;">
                <children>
                    <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 empleados"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#fnVolverMenu" text="← Volver" styleClass="btn, btn-secondary"/>
                </children>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>