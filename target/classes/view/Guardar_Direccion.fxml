<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Guardar_direccion_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="SISTEMA — CONFIGURACIÓN"/>
                <Label styleClass="header-title" text="Registro de Nueva Dirección"/>
            </children>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="bg-main">
            <children>
                <VBox maxWidth="800" spacing="32" alignment="TOP_CENTER" style="-fx-padding: 40;">
                    <children>
                        <VBox spacing="24" styleClass="card">
                            <children>
                                <Label styleClass="card-title" text="Detalles de Ubicación"/>

                                <GridPane hgap="24" vgap="20">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <children>
                                        <Label styleClass="form-label" text="Calle *" GridPane.rowIndex="0"/>
                                        <TextField fx:id="txtCalle" promptText="Nombre de la vía o calle" styleClass="input-tall" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label styleClass="form-label" text="Número/Apto *" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtNumero" promptText="Ej: 12-B o #45" styleClass="input-tall" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label styleClass="form-label" text="Sector/Barrio" GridPane.rowIndex="2"/>
                                        <TextField fx:id="txtSector" promptText="Ej: Ensanche Naco" styleClass="input-tall" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label styleClass="form-label" text="Ciudad *" GridPane.rowIndex="3"/>
                                        <TextField fx:id="txtCiudad" promptText="Ej: Santiago de los Caballeros" styleClass="input-tall" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label styleClass="form-label" text="Provincia *" GridPane.rowIndex="4"/>
                                        <ComboBox fx:id="cmbProvincia" maxWidth="Infinity" promptText="Seleccionar provincia..." styleClass="input-tall" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                        <Label styleClass="form-label" text="Referencia" GridPane.rowIndex="5"/>
                                        <TextArea fx:id="txtReferencia" promptText="Ej: Frente al parque, casa color azul..." wrapText="true" styleClass="textarea-tall" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <children>
                                <Button onAction="#fnLimpiarFormulario" text="Limpiar" styleClass="btn, btn-secondary, button-tall"/>
                                <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary, button-tall"/>
                                <Button onAction="#fnGuardarDireccion" text="Guardar Dirección" styleClass="btn, btn-primary, button-tall"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="footer-bar" style="-fx-padding: 12 24;">
            <children>
                <Label styleClass="text-placeholder" text="SUDO ERP — Gestión de Logística"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>