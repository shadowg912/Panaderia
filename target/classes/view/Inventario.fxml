<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Inventario_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — INVENTARIO"/>
                <Label styleClass="header-title" text="Ver Productos"/>
                <Label styleClass="text-accent" text="Productos registrados en el sistema"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card">
                    <children>
                        <VBox spacing="5">
                            <Label styleClass="label-small" text="CATEGORÍA"/>
                            <ComboBox fx:id="cmbCategoria" onAction="#fnFiltrarCategoria" prefWidth="200" promptText="Todas las categorías"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label styleClass="label-small" text="BUSCAR"/>
                            <TextField fx:id="txtBuscar" onAction="#fnBuscar" prefWidth="250" promptText="Buscar por nombre..."/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
                    </children>
                </HBox>

                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="280" text="NOMBRE"/>
                        <TableColumn fx:id="colCategoria" prefWidth="200" text="CATEGORÍA"/>
                        <TableColumn fx:id="colPrecio" prefWidth="120" text="PRECIO (RD$)"/>
                        <TableColumn fx:id="colUnidad" prefWidth="120" text="UNIDAD"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 10 0;">
                    <children>
                        <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 productos"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>