<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Inventario_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — INVENTARIO"/>
            <Label styleClass="header-title" text="Gestión de Stock"/>
            <Label styleClass="text-accent" text="Control de inventario y movimientos"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <VBox spacing="5">
                    <Label styleClass="label-small" text="CATEGORÍA"/>
                    <ComboBox fx:id="cmbCategoria" onAction="#fnFiltrarCategoria" prefWidth="200" promptText="Todas las categorías"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="label-small" text="BUSCAR"/>
                    <TextField fx:id="txtBuscar" onAction="#fnBuscar" prefWidth="250" promptText="Buscar por nombre..."/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStockBajo" styleClass="badge" text="" visible="false"/>
                <Button onAction="#fnVolverMenu" text="Volver" styleClass="btn, btn-secondary"/>
            </HBox>

            <TableView fx:id="tablaProductos" prefHeight="300" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colNombre" prefWidth="220" text="PRODUCTO"/>
                    <TableColumn fx:id="colCategoria" prefWidth="150" text="CATEGORÍA"/>
                    <TableColumn fx:id="colStock" prefWidth="100" text="STOCK"/>
                    <TableColumn fx:id="colPrecio" prefWidth="120" text="PRECIO (RD$)"/>
                    <TableColumn fx:id="colUnidad" prefWidth="100" text="UNIDAD"/>
                    <TableColumn fx:id="colTipo" prefWidth="140" text="TIPO"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <TitledPane text="Historial de Movimientos" expanded="false">
                <VBox spacing="12">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label styleClass="label-small" text="FILTRAR PRODUCTO"/>
                        <ComboBox fx:id="cmbFiltroMovimiento" prefWidth="250" promptText="Todos los productos"/>
                        <Label styleClass="label-small" text="TIPO"/>
                        <ComboBox fx:id="cmbTipoMovimiento" prefWidth="150" promptText="Todos"/>
                    </HBox>
                    <TableView fx:id="tablaMovimientos" prefHeight="200" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colMovFecha" prefWidth="140" text="FECHA"/>
                            <TableColumn fx:id="colMovProducto" prefWidth="200" text="PRODUCTO"/>
                            <TableColumn fx:id="colMovTipo" prefWidth="100" text="TIPO"/>
                            <TableColumn fx:id="colMovCantidad" prefWidth="100" text="CANTIDAD"/>
                            <TableColumn fx:id="colMovStock" prefWidth="100" text="STOCK RESULTANTE"/>
                            <TableColumn fx:id="colMovUsuario" prefWidth="150" text="USUARIO"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </TitledPane>

            <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 6 0 0 0;">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 productos"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
