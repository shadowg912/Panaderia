<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #F5F2EB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" >

    <top>
        <VBox style="-fx-background-color: #CDB08E; -fx-padding: 16 24; -fx-border-color: #BFB6A6; -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4A4944;" text="PANADERÍA — POSTVENTA" />
                <Label style="-fx-font-size: 24px; -fx-text-fill: #11100B; -fx-font-weight: bold;" text="Gestión de Reclamaciones" />
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F5F2EB; -fx-background: #F5F2EB; -fx-border-color: transparent;">
            <content>
                <VBox alignment="TOP_CENTER" spacing="32" style="-fx-padding: 40; -fx-background-color: #F5F2EB;">
                    <HBox alignment="TOP_CENTER" spacing="32">

                        <VBox spacing="20" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-border-color: #BFB6A6; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-min-width: 500;">
                            <children>
                                <Label style="-fx-font-size: 16px; -fx-text-fill: #CDB08E; -fx-font-weight: bold;" text="DATOS DE ORIGEN" />
                                <GridPane hgap="16" vgap="16">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="130" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label style="-fx-text-fill: #4A4944;" text="ID Factura *" GridPane.rowIndex="0" />
                                        <TextField fx:id="txtIdFactura" promptText="Número de factura" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6; -fx-padding: 10; -fx-text-fill: #11100B;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-text-fill: #4A4944;" text="ID Cliente *" GridPane.rowIndex="1" />
                                        <TextField fx:id="txtIdCliente" promptText="ID de empresa cliente" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6; -fx-padding: 10; -fx-text-fill: #11100B;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label style="-fx-text-fill: #4A4944;" text="ID Empleado" GridPane.rowIndex="2" />
                                        <TextField fx:id="txtIdEmpleado" promptText="ID del responsable" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6; -fx-padding: 10; -fx-text-fill: #11100B;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="20" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-border-color: #BFB6A6; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-min-width: 500;">
                            <children>
                                <Label style="-fx-font-size: 16px; -fx-text-fill: #CDB08E; -fx-font-weight: bold;" text="ESTADO Y PRIORIDAD" />
                                <GridPane hgap="16" vgap="16">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="130" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label style="-fx-text-fill: #4A4944;" text="Tipo *" GridPane.rowIndex="0" />
                                        <TextField fx:id="txtTipoReclamacion" promptText="Ej: Devolución" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6; -fx-padding: 10; -fx-text-fill: #11100B;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label style="-fx-text-fill: #4A4944;" text="Estado *" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="cmbEstado" maxWidth="Infinity" prefHeight="42.0" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6; -fx-text-fill: #11100B;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="ABIERTA" />
                                                    <String fx:value="EN_PROCESO" />
                                                    <String fx:value="RESUELTA" />
                                                    <String fx:value="CERRADA" />
                                                </FXCollections>
                                            </items>
                                            <value><String fx:value="ABIERTA" /></value>
                                        </ComboBox>

                                        <Label style="-fx-text-fill: #4A4944;" text="Prioridad *" GridPane.rowIndex="2" />
                                        <ComboBox fx:id="cmbPrioridad" maxWidth="Infinity" prefHeight="42.0" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6; -fx-text-fill: #11100B;" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="BAJA" />
                                                    <String fx:value="MEDIA" />
                                                    <String fx:value="ALTA" />
                                                </FXCollections>
                                            </items>
                                            <value><String fx:value="MEDIA" /></value>
                                        </ComboBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </HBox>

                    <VBox maxWidth="1032" spacing="12" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-border-color: #BFB6A6; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                        <children>
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #CDB08E; -fx-font-weight: bold;" text="MOTIVO DEL RECLAMO" />
                            <TextArea fx:id="txtMotivo" prefHeight="100" promptText="Escriba aquí los detalles..." style="-fx-control-inner-background: #F5F2EB; -fx-text-fill: #11100B; -fx-border-color: #BFB6A6;" wrapText="true" />
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" maxWidth="1032" spacing="16">
                        <children>
                            <Button fx:id="btnLimpiar"  style="-fx-background-color: #BFB6A6; -fx-text-fill: #11100B; -fx-padding: 11 28; -fx-border-radius: 8;" text="Limpiar" />
                            <Button fx:id="btnCancelar"  style="-fx-background-color: #BFB6A6; -fx-text-fill: #11100B; -fx-padding: 11 28; -fx-border-radius: 8;" text="Cancelar" />
                            <Button fx:id="btnGuardar"  style="-fx-background-color: #CDB08E; -fx-text-fill: #11100B; -fx-padding: 11 32; -fx-font-weight: bold; -fx-background-radius: 8;" text="Guardar Reclamación" />
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #CDB08E; -fx-padding: 12; -fx-border-color: #BFB6A6; -fx-border-width: 1 0 0 0;" />
    </bottom>
</BorderPane>