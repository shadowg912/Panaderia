<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Gestion_ingredientes_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — INVENTARIO"/>
            <Label styleClass="header-title" text="Gestión de Ingredientes"/>
            <Label styleClass="text-accent" text="Administrar ingredientes utilizados en producción"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card" style="-fx-padding: 16 20;">
                <Label styleClass="label-small" text="NOMBRE"/>
                <TextField fx:id="txtBuscar" promptText="Buscar ingrediente..." HBox.hgrow="ALWAYS"/>
                <Button onAction="#fnBuscar" text="Buscar" styleClass="btn, btn-primary"/>
                <Button onAction="#fnNuevo" text="Nuevo" styleClass="btn, btn-success"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#fnVolver" text="Volver" styleClass="btn, btn-secondary"/>
            </HBox>

            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaIngredientes" prefHeight="400" HBox.hgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                        <TableColumn fx:id="colNombre" prefWidth="200" text="NOMBRE"/>
                        <TableColumn fx:id="colUnidad" prefWidth="120" text="UNIDAD"/>
                        <TableColumn fx:id="colCategoria" prefWidth="180" text="CATEGORÍA"/>
                        <TableColumn fx:id="colEstado" prefWidth="100" text="ESTADO"/>
                        <TableColumn fx:id="colAccion" prefWidth="120" text="ACCIÓN"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <VBox spacing="16" styleClass="card" prefWidth="360" style="-fx-padding: 20 24;">
                    <Label styleClass="card-title">
                        <text>
                            <fx:script><![CDATA[ binding { var editando -> "" } ]]></fx:script>
                            <Label fx:id="lblTituloForm" text="Nuevo Ingrediente"/>
                        </text>
                    </Label>
                    <VBox spacing="8">
                        <Label styleClass="label-small" text="NOMBRE *"/>
                        <TextField fx:id="txtNombre" promptText="Nombre del ingrediente"/>
                    </VBox>
                    <VBox spacing="8">
                        <Label styleClass="label-small" text="UNIDAD DE MEDIDA *"/>
                        <ComboBox fx:id="cmbUnidad" editable="true" promptText="Seleccione o escriba..." maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="8">
                        <Label styleClass="label-small" text="CATEGORÍA *"/>
                        <ComboBox fx:id="cmbCategoria" promptText="Seleccione una categoría" maxWidth="Infinity"/>
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 8 0 0 0;">
                        <Button fx:id="btnCancelar" onAction="#fnCancelar" text="Cancelar" styleClass="btn, btn-secondary"/>
                        <Button fx:id="btnGuardar" onAction="#fnGuardar" text="Guardar" styleClass="btn, btn-primary"/>
                    </HBox>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblTotalRegistros" styleClass="text-placeholder" text="Total: 0 ingredientes"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
