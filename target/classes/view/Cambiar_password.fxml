<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Cambiar_password_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <Label styleClass="header-subtitle" text="PANADERÍA — SEGURIDAD"/>
            <Label styleClass="header-title" text="Cambiar Contraseña"/>
            <Label styleClass="text-accent" text="Actualice su contraseña de acceso al sistema"/>
        </VBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="24" style="-fx-padding: 48 32;">
            <VBox spacing="20" styleClass="card" maxWidth="520" style="-fx-padding: 32 40;">
                <Label styleClass="card-title" text="Nueva Contraseña"/>
                <GridPane styleClass="form-grid" vgap="12" hgap="16">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="140"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>
                    <Label styleClass="form-label" text="Contraseña actual" GridPane.rowIndex="0"/>
                    <PasswordField fx:id="txtPasswordActual" promptText="Ingrese su contraseña actual" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label styleClass="form-label" text="Nueva contraseña" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="txtPasswordNueva" promptText="Mínimo 8 caracteres" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label styleClass="form-label" text="Confirmar contraseña" GridPane.rowIndex="2"/>
                    <PasswordField fx:id="txtConfirmarPassword" promptText="Repita la nueva contraseña" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <HBox styleClass="info-box">
                    <Label text="La contraseña debe tener al menos 8 caracteres." wrapText="true" style="-fx-font-size: 12px;"/>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="16" style="-fx-padding: 8 0 0 0;">
                    <Button onAction="#fnVolver" text="Volver" styleClass="btn, btn-secondary"/>
                    <Button onAction="#fnCambiarPassword" text="Cambiar Contraseña" styleClass="btn, btn-primary"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>
