<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Login_controller">

    <center>
        <StackPane styleClass="login-root">
            <VBox alignment="CENTER" maxWidth="420" spacing="0" styleClass="login-card">
                <VBox alignment="CENTER" spacing="4" styleClass="login-header">
                    <Label styleClass="login-icon" text="🥖"/>
                    <Label styleClass="login-title" text="Panadería"/>
                    <Label styleClass="login-subtitle" text="Sistema Integral de Gestión"/>
                </VBox>

                <VBox spacing="20" styleClass="login-body">
                    <Label styleClass="card-title" text="Iniciar Sesión"/>

                    <VBox spacing="5">
                        <Label styleClass="form-label" text="Usuario"/>
                        <TextField fx:id="txtUsuario" promptText="Nombre de usuario" onAction="#fnIniciarSesion" styleClass="login-input"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="form-label" text="Contraseña"/>
                        <PasswordField fx:id="txtPassword" promptText="Contraseña" onAction="#fnIniciarSesion" styleClass="login-input"/>
                    </VBox>

                    <Button maxWidth="Infinity" text="Iniciar Sesión" onAction="#fnIniciarSesion" styleClass="btn, btn-primary">
                        <effect>
                            <DropShadow blurType="GAUSSIAN" color="#cdb08e66" radius="16" spread="0.1"/>
                        </effect>
                    </Button>
                </VBox>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar">
            <Label styleClass="text-placeholder" text="© 2026 Panadería — Todos los derechos reservados"/>
        </HBox>
    </bottom>
</BorderPane>
