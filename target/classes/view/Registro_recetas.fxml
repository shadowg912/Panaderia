<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane stylesheets="@Table.css, @Combobox.css"

            fx:controller="controllers.Registro_recetas_controller"
            prefHeight="720" prefWidth="1280"
            style="-fx-background-color: #F5F2EB;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #CDB08E;
                     -fx-padding: 16 24;
                     -fx-border-color: #BFB6A6;
                     -fx-border-width: 0 0 1 0;"
              spacing="16">
            <children>

                <Button onAction="#fnVolverMenu"
                        prefHeight="40" prefWidth="40"
                        style="-fx-background-color: #F5F2EB;
                               -fx-text-fill: #4A4944;
                               -fx-font-size: 18px;
                               -fx-border-color: #BFB6A6;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;"
                        text="←" />

                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 10px; -fx-font-weight: bold;
                                      -fx-text-fill: #4A4944; -fx-letter-spacing: 2;"
                               text="PANADERÍA — PRODUCCIÓN" />
                        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #11100B;"
                               text="Configuración de Receta" />
                        <Label style="-fx-text-fill: #4A4944; -fx-font-size: 12px;"
                               text="Asigne los ingredientes y cantidades por producto" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #F5F2EB;
                           -fx-background: #F5F2EB;
                           -fx-border-color: transparent;">
            <content>
                <VBox spacing="20"
                      style="-fx-padding: 28 40; -fx-alignment: TOP_CENTER;">

                    <VBox spacing="14"
                          style="-fx-background-color: #FFFFFF;
                                 -fx-padding: 20 24;
                                 -fx-border-color: #BFB6A6;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-max-width: 980;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <children>
                                    <Label style="-fx-background-color: #CDB08E;
                                                  -fx-text-fill: #11100B;
                                                  -fx-font-weight: bold;
                                                  -fx-font-size: 11px;
                                                  -fx-padding: 2 8;
                                                  -fx-background-radius: 4;"
                                           text="PASO 1" />
                                    <Label style="-fx-font-size: 15px;
                                                  -fx-text-fill: #11100B;
                                                  -fx-font-weight: bold;"
                                           text="Producto Final" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <children>
                                    <Label style="-fx-text-fill: #4A4944;
                                                  -fx-font-size: 13px;
                                                  -fx-min-width: 160;"
                                           text="Producto a Elaborar:" />
                                    <ComboBox fx:id="cmbProducto"
                                              maxWidth="Infinity"
                                              prefHeight="42"
                                              promptText="Seleccione el producto..."
                                              style="-fx-background-color: #F5F2EB;
                                                     -fx-border-color: #BFB6A6;
                                                     -fx-border-radius: 8;
                                                     -fx-background-radius: 8;
                                                     -fx-text-fill: #11100B;
                                                     -fx-font-size: 13px;"
                                              HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="14"
                          style="-fx-background-color: #FFFFFF;
                                 -fx-padding: 20 24;
                                 -fx-border-color: #BFB6A6;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-max-width: 980;">
                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <children>
                                    <Label style="-fx-background-color: #BFB6A6;
                                                  -fx-text-fill: #11100B;
                                                  -fx-font-weight: bold;
                                                  -fx-font-size: 11px;
                                                  -fx-padding: 2 8;
                                                  -fx-background-radius: 4;"
                                           text="PASO 2" />
                                    <Label style="-fx-font-size: 15px;
                                                  -fx-text-fill: #11100B;
                                                  -fx-font-weight: bold;"
                                           text="Agregar Ingredientes" />
                                </children>
                            </HBox>

                            <HBox alignment="BOTTOM_LEFT" spacing="12"
                                  style="-fx-background-color: #F5F2EB;
                                         -fx-padding: 16;
                                         -fx-background-radius: 8;
                                         -fx-border-color: #BFB6A6;
                                         -fx-border-radius: 8;">
                                <children>

                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label style="-fx-text-fill: #4A4944;
                                                          -fx-font-size: 11px;
                                                          -fx-font-weight: bold;"
                                                   text="INGREDIENTE" />
                                            <ComboBox fx:id="cmbIngrediente"
                                                      maxWidth="Infinity"
                                                      prefHeight="42"
                                                      promptText="Buscar ingrediente..."
                                                      style="-fx-background-color: #FFFFFF;
                                                             -fx-border-color: #BFB6A6;
                                                             -fx-border-radius: 8;
                                                             -fx-background-radius: 8;
                                                             -fx-text-fill: #11100B;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6" prefWidth="160">
                                        <children>
                                            <Label style="-fx-text-fill: #4A4944;
                                                          -fx-font-size: 11px;
                                                          -fx-font-weight: bold;"
                                                   text="CANTIDAD" />
                                            <TextField fx:id="txtCantidadIngrediente"
                                                       prefHeight="42"
                                                       promptText="0.00"
                                                       style="-fx-background-color: #FFFFFF;
                                                              -fx-text-fill: #11100B;
                                                              -fx-border-color: #BFB6A6;
                                                              -fx-border-radius: 8;
                                                              -fx-background-radius: 8;
                                                              -fx-font-size: 14px;" />
                                        </children>
                                    </VBox>

                                    <VBox spacing="6">
                                        <children>
                                            <Label style="-fx-text-fill: transparent;
                                                          -fx-font-size: 11px;"
                                                   text="." />
                                            <Button fx:id="btnAgregarALista"
                                                    onAction="#fnAgregarALista"
                                                    prefHeight="42" prefWidth="130"
                                                    style="-fx-background-color: #CDB08E;
                                                           -fx-text-fill: #11100B;
                                                           -fx-font-weight: bold;
                                                           -fx-font-size: 13px;
                                                           -fx-background-radius: 8;
                                                           -fx-cursor: hand;"
                                                    text="＋ Añadir" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <TableView fx:id="tblRecetaDetalle"
                                       prefHeight="260"
                                       maxWidth="Infinity"
                                       styleClass="dark-table"
                                       style="-fx-background-color: #FFFFFF;
                                              -fx-border-color: #BFB6A6;
                                              -fx-border-radius: 8;">
                                <columns>
                                    <TableColumn fx:id="colIdIngrediente" prefWidth="80" minWidth="60" text="ID" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colNombreIngrediente" prefWidth="420" minWidth="200" text="Ingrediente" />
                                    <TableColumn fx:id="colCantidad" prefWidth="140" minWidth="100" text="Cantidad" style="-fx-alignment: CENTER_RIGHT;" />
                                    <TableColumn fx:id="colUnidad" prefWidth="150" minWidth="100" text="Unidad de Medida" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colAccion" prefWidth="110" minWidth="100" text="Eliminar" style="-fx-alignment: CENTER;" resizable="false" />
                                </columns>
                                <placeholder>
                                    <Label style="-fx-text-fill: #4A4944;
                                                  -fx-font-size: 13px;"
                                           text="Aún no se han añadido ingredientes" />
                                </placeholder>
                            </TableView>

                        </children>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT"
                          maxWidth="980"
                          spacing="12"
                          style="-fx-padding: 0 0 20 0;">
                        <children>

                            <Button onAction="#fnVolverMenu"
                                    prefHeight="44" prefWidth="160"
                                    style="-fx-background-color: transparent;
                                           -fx-text-fill: #4A4944;
                                           -fx-border-color: #BFB6A6;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;"
                                    text="Cancelar" />

                            <Button onAction="#fnLimpiar"
                                    prefHeight="44" prefWidth="150"
                                    style="-fx-background-color: #BFB6A6;
                                           -fx-text-fill: #11100B;
                                           -fx-border-color: #BFB6A6;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-font-size: 13px;
                                           -fx-cursor: hand;"
                                    text="Limpiar" />

                            <Button fx:id="btnGuardarReceta"
                                    onAction="#fnGuardarReceta"
                                    prefHeight="44" prefWidth="230"
                                    style="-fx-background-color: #CDB08E;
                                           -fx-text-fill: #11100B;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-font-size: 14px;
                                           -fx-cursor: hand;"
                                    text="Guardar Receta" />
                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>