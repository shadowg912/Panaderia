<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Registro_recetas_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-bar">
            <children>
                <Button onAction="#fnVolverMenu" prefHeight="40" prefWidth="40" styleClass="btn-icon" text="←"/>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="header-subtitle" text="PANADERÍA — PRODUCCIÓN"/>
                        <Label styleClass="header-title" text="Configuración de Receta"/>
                        <Label styleClass="text-placeholder" text="Asigne los ingredientes y cantidades por producto"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox spacing="20" style="-fx-padding: 28 40; -fx-alignment: TOP_CENTER;">
                    <children>
                        <!-- SECCIÓN 1: Producto -->
                        <VBox spacing="14" styleClass="card" style="-fx-max-width: 980;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label styleClass="badge" text="PASO 1"/>
                                        <Label styleClass="section-title" text="Producto Final"/>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <children>
                                        <Label styleClass="form-label" style="-fx-min-width: 160;" text="Producto a Elaborar:"/>
                                        <ComboBox fx:id="cmbProducto" maxWidth="Infinity" prefHeight="42" promptText="Seleccione el producto..." HBox.hgrow="ALWAYS"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- SECCIÓN 2: Agregar ingrediente -->
                        <VBox spacing="14" styleClass="card" style="-fx-max-width: 980;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label styleClass="badge-accent" text="PASO 2"/>
                                        <Label styleClass="section-title" text="Agregar Ingredientes"/>
                                    </children>
                                </HBox>

                                <HBox alignment="BOTTOM_LEFT" spacing="12" styleClass="input-row">
                                    <children>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="label-small" text="INGREDIENTE"/>
                                                <ComboBox fx:id="cmbIngrediente" maxWidth="Infinity" prefHeight="42" promptText="Buscar ingrediente..."/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="6" prefWidth="120">
                                            <children>
                                                <Label styleClass="label-small" text="CANTIDAD"/>
                                                <TextField fx:id="txtCantidadIngrediente" prefHeight="42" promptText="0.00"/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="6" prefWidth="140">
                                            <children>
                                                <Label styleClass="label-small" text="UNIDAD"/>
                                                <ComboBox fx:id="cmbUnidad" prefHeight="42" promptText="Seleccionar..."/>
                                            </children>
                                        </VBox>

                                        <VBox spacing="6">
                                            <children>
                                                <Label style="-fx-text-fill: transparent; -fx-font-size: 11px;" text="."/>
                                                <Button fx:id="btnAgregarALista" onAction="#fnAgregarALista" prefHeight="42" prefWidth="130" styleClass="btn, btn-accent" text="＋ Añadir"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <TableView fx:id="tblRecetaDetalle" prefHeight="260" maxWidth="Infinity" styleClass="table-view">
                                    <columns>
                                        <TableColumn fx:id="colIdIngrediente" prefWidth="80" minWidth="60" text="ID"/>
                                        <TableColumn fx:id="colNombreIngrediente" prefWidth="420" minWidth="200" text="Ingrediente"/>
                                        <TableColumn fx:id="colCantidad" prefWidth="140" minWidth="100" text="Cantidad"/>
                                        <TableColumn fx:id="colUnidad" prefWidth="150" minWidth="100" text="Unidad de Medida"/>
                                        <TableColumn fx:id="colAccion" prefWidth="110" minWidth="100" text="Eliminar" resizable="false"/>
                                    </columns>
                                    <placeholder>
                                        <Label styleClass="text-placeholder" text="Aún no se han añadido ingredientes"/>
                                    </placeholder>
                                </TableView>
                            </children>
                        </VBox>

                        <!-- BARRA DE ACCIONES -->
                        <HBox alignment="CENTER_RIGHT" maxWidth="980" spacing="12" style="-fx-padding: 0 0 20 0;">
                            <children>
                                <Button onAction="#fnVolverMenu" prefHeight="44" prefWidth="160" styleClass="btn, btn-ghost" text="Cancelar"/>
                                <Button onAction="#fnLimpiar" prefHeight="44" prefWidth="150" styleClass="btn, btn-secondary" text="Limpiar"/>
                                <Button fx:id="btnGuardarReceta" onAction="#fnGuardarReceta" prefHeight="44" prefWidth="230" styleClass="btn, btn-primary" text="Guardar Receta"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>