<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@Combobox.css" prefHeight="720" prefWidth="1280" style="-fx-background-color: #F5F2EB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Crear_usuario_controller">

    <top>
        <VBox style="-fx-background-color: #CDB08E; -fx-padding: 16 24; -fx-border-color: #BFB6A6; -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4A4944; -fx-letter-spacing: 2;" text="PANADERÍA — ADMINISTRACIÓN"/>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #11100B;" text="Creación de Usuario"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane style="-fx-background-color: #F5F2EB; -fx-background: #F5F2EB;">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32; -fx-background-color: #F5F2EB;">

                    <HBox alignment="TOP_CENTER" spacing="28">

                        <VBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-border-color: #BFB6A6; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-min-width: 500;">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #CDB08E;" text="Datos Personales"/>

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="150"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <children>
                                        <Label style="-fx-text-fill: #4A4944; -fx-font-size: 13px;" text="Nombre *"/>
                                        <TextField fx:id="txtNombre" promptText="Ej: María González" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-prompt-text-fill: #BFB6A6; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1"/>

                                        <Label style="-fx-text-fill: #4A4944; -fx-font-size: 13px;" text="Apellido *" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtApellido" promptText="Ej: Pérez" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-prompt-text-fill: #BFB6A6; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label style="-fx-text-fill: #4A4944; -fx-font-size: 13px;" text="Correo *" GridPane.rowIndex="2"/>
                                        <TextField fx:id="txtCorreo" promptText="usuario@panaderia.com" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-prompt-text-fill: #BFB6A6; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label style="-fx-text-fill: #4A4944; -fx-font-size: 13px;" text="Teléfono" GridPane.rowIndex="3"/>
                                        <TextField fx:id="txtTelefono" promptText="809-000-0000" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-prompt-text-fill: #BFB6A6; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label style="-fx-text-fill: #4A4944; -fx-font-size: 13px;" text="Cargo / Puesto" GridPane.rowIndex="4"/>
                                        <TextField fx:id="txtPuesto" promptText="Ej: Cajero, Supervisor" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-prompt-text-fill: #BFB6A6; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-padding: 24; -fx-border-color: #BFB6A6; -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10; -fx-min-width: 450;">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #CDB08E;" text="Credenciales y Permisos"/>

                                <GridPane hgap="16" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="150"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <children>
                                        <Label style="-fx-text-fill: #4A4944;" text="Nombre de usuario *"/>
                                        <TextField fx:id="txtUsuario" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1"/>

                                        <Label style="-fx-text-fill: #4A4944;" text="Contraseña *" GridPane.rowIndex="1"/>
                                        <PasswordField fx:id="txtPassword" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label style="-fx-text-fill: #4A4944;" text="Confirmar contraseña *" GridPane.rowIndex="2"/>
                                        <PasswordField fx:id="txtConfirmarPassword" style="-fx-background-color: #F5F2EB; -fx-text-fill: #11100B; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label style="-fx-text-fill: #4A4944;" text="Rol *" GridPane.rowIndex="3"/>
                                        <ComboBox fx:id="cmbRol" style="-fx-background-color: #F5F2EB; -fx-border-color: #BFB6A6;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label style="-fx-text-fill: #4A4944;" text="Estado" GridPane.rowIndex="4"/>
                                        <HBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                            <children>
                                                <RadioButton fx:id="rbActivo" selected="true" style="-fx-text-fill: #4A4944;" text="Activo"/>
                                                <RadioButton fx:id="rbInactivo" style="-fx-text-fill: #4A4944;" text="Inactivo"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </GridPane>

                                <HBox spacing="12" style="-fx-background-color: #F5F2EB; -fx-border-color: #CDB08E; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12;">
                                    <children>
                                        <Label style="-fx-font-size: 18px;" text="🔒"/>
                                        <Label maxWidth="310" style="-fx-text-fill: #4A4944; -fx-font-size: 12px;" text="La contraseña debe tener al menos 8 caracteres, una mayúscula y un número." wrapText="true"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="16">
                        <children>

                            <Button fx:id="btnCrearEmpleado" onAction="#fnCrearEmpleado"
                                    style="-fx-background-color: #CDB08E; -fx-text-fill: #11100B; -fx-font-weight: bold;"
                                    text="Crear Empleado"/>

                            <Button fx:id="btnLimpiar" onAction="#fnLimpiar"
                                    style="-fx-background-color: #BFB6A6; -fx-text-fill: #11100B;"
                                    text="Limpiar Formulario"/>

                            <Button fx:id="btnCancelar" onAction="#fnVolverMenu"
                                    style="-fx-background-color: #BFB6A6; -fx-text-fill: #11100B;"
                                    text="Cancelar"/>

                            <Button fx:id="btnCrearUsuario" onAction="#fnCrearUsuario"
                                    style="-fx-background-color: #CDB08E; -fx-text-fill: #11100B; -fx-font-weight: bold;"
                                    text="Crear Usuario"/>

                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #CDB08E; -fx-padding: 12; -fx-border-color: #BFB6A6; -fx-border-width: 1 0 0 0;"/>
    </bottom>

</BorderPane>