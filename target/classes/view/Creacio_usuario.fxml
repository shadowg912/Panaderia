<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Crear_usuario_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — ADMINISTRACIÓN"/>
                <Label styleClass="header-title" text="Creación de Usuario"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane styleClass="scroll-pane">
            <content>
                <VBox alignment="CENTER" spacing="24" style="-fx-padding: 32;">
                    <HBox alignment="TOP_CENTER" spacing="28">
                        <VBox spacing="16" styleClass="card" style="-fx-min-width: 500;">
                            <children>
                                <Label styleClass="card-title" text="Datos Personales"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="150"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="Nombre *" GridPane.rowIndex="0"/>
                                        <TextField fx:id="txtNombre" promptText="Ej: María González" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                        <Label styleClass="form-label" text="Apellido *" GridPane.rowIndex="1"/>
                                        <TextField fx:id="txtApellido" promptText="Ej: Pérez" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                        <Label styleClass="form-label" text="Correo *" GridPane.rowIndex="2"/>
                                        <TextField fx:id="txtCorreo" promptText="usuario@panaderia.com" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                        <Label styleClass="form-label" text="Teléfono" GridPane.rowIndex="3"/>
                                        <TextField fx:id="txtTelefono" promptText="809-000-0000" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                        <Label styleClass="form-label" text="Cargo / Puesto" GridPane.rowIndex="4"/>
                                        <TextField fx:id="txtPuesto" promptText="Ej: Cajero, Supervisor" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="16" styleClass="card" style="-fx-min-width: 450;">
                            <children>
                                <Label styleClass="card-title" text="Credenciales y Permisos"/>
                                <GridPane styleClass="form-grid">
                                    <columnConstraints>
                                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="150"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                        <RowConstraints/>
                                    </rowConstraints>
                                    <children>
                                        <Label styleClass="form-label" text="Nombre de usuario *" GridPane.rowIndex="0"/>
                                        <TextField fx:id="txtUsuario" promptText="Ej: mgonzalez" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                        <Label styleClass="form-label" text="Contraseña *" GridPane.rowIndex="1"/>
                                        <PasswordField fx:id="txtPassword" promptText="Mínimo 8 caracteres" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                        <Label styleClass="form-label" text="Confirmar contraseña *" GridPane.rowIndex="2"/>
                                        <PasswordField fx:id="txtConfirmarPassword" promptText="Repita la contraseña" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                        <Label styleClass="form-label" text="Rol *" GridPane.rowIndex="3"/>
                                        <ComboBox fx:id="cmbRol" promptText="Seleccione un rol" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                        <Label styleClass="form-label" text="Estado" GridPane.rowIndex="4"/>
                                        <HBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                            <children>
                                                <RadioButton fx:id="rbActivo" selected="true" styleClass="radio-light" text="Activo"/>
                                                <RadioButton fx:id="rbInactivo" styleClass="radio-light" text="Inactivo"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </GridPane>
                                <HBox styleClass="info-box">
                                    <children>
                                        <Label style="-fx-font-size: 18px;" text="🔒"/>
                                        <Label maxWidth="310" text="La contraseña debe tener al menos 8 caracteres, una mayúscula y un número." wrapText="true"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="16">
                        <children>
                            <Button fx:id="btnCrearEmpleado" onAction="#fnCrearEmpleado" text="Crear Empleado" styleClass="btn, btn-success"/>
                            <Button fx:id="btnLimpiar" onAction="#fnLimpiar" text="Limpiar Formulario" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnCancelar" onAction="#fnVolverMenu" text="Cancelar" styleClass="btn, btn-secondary"/>
                            <Button fx:id="btnCrearUsuario" onAction="#fnCrearUsuario" text="Crear Usuario" styleClass="btn, btn-primary"/>
                        </children>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>