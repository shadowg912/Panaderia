<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — LOGÍSTICA"/>
                <Label styleClass="header-title" text="Seguimiento de Envío"/>
                <Label styleClass="text-accent" text="Factura: FV-2026-0087 | Cliente: Supermercados del Caribe SRL"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <content>
                <VBox spacing="32" style="-fx-padding: 40;">
                    <children>
                        <VBox spacing="24" styleClass="card">
                            <children>
                                <Label styleClass="section-title" text="ESTADO DEL ENVÍO"/>

                                <HBox alignment="CENTER" spacing="40">
                                    <children>
                                        <VBox alignment="CENTER" spacing="8" style="-fx-min-width: 200;">
                                            <children>
                                                <Label styleClass="text-accent" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="● PENDIENTE"/>
                                                <Label styleClass="form-label" text="Preparación en bodega"/>
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="8" style="-fx-min-width: 200; -fx-opacity: 0.4;">
                                            <children>
                                                <Label styleClass="text-placeholder" style="-fx-font-size: 18px;" text="○ EN CAMINO"/>
                                                <Label styleClass="text-placeholder" text="En reparto"/>
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="8" style="-fx-min-width: 200; -fx-opacity: 0.4;">
                                            <children>
                                                <Label styleClass="text-placeholder" style="-fx-font-size: 18px;" text="○ ENTREGADO"/>
                                                <Label styleClass="text-placeholder" text="Confirmación final"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Separator styleClass="separator-dark"/>

                                <GridPane hgap="40" alignment="CENTER">
                                    <children>
                                        <HBox spacing="10" GridPane.columnIndex="0">
                                            <Label styleClass="text-placeholder" text="Fecha estimada:"/>
                                            <Label styleClass="text-body" style="-fx-font-weight: bold;" text="18/02/2026"/>
                                        </HBox>
                                        <HBox spacing="10" GridPane.columnIndex="1">
                                            <Label styleClass="text-placeholder" text="Costo de envío:"/>
                                            <Label styleClass="text-accent" style="-fx-font-weight: bold;" text="RD$ 150.00"/>
                                        </HBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="16">
                            <children>
                                <Label styleClass="section-title" text="HISTORIAL DE MOVIMIENTOS"/>
                                <ListView prefHeight="180" styleClass="list-view"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <children>
                                <Button text="Volver" styleClass="btn, btn-secondary"/>
                                <Button text="Imprimir Guía" styleClass="btn, btn-secondary"/>
                                <Button text="Actualizar Estado" styleClass="btn, btn-primary"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>