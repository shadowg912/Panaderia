<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@Styles.css"
            fx:controller="controllers.Seguimento_envio_controller"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox styleClass="header-bar">
            <children>
                <Label styleClass="header-subtitle" text="PANADERÍA — LOGÍSTICA"/>
                <Label styleClass="header-title" text="Seguimiento de Envíos"/>
                <Label styleClass="text-accent" text="Gestione y supervise las entregas de órdenes de venta"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-padding: 32;">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card">
                <children>
                    <VBox spacing="5" prefWidth="120">
                        <Label styleClass="label-small" text="ORDEN #"/>
                        <TextField fx:id="txtIdOrden" promptText="ID orden"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="label-small" text="ESTADO"/>
                        <ComboBox fx:id="cmbEstado" prefWidth="160" promptText="Todos los estados"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label styleClass="label-small" text="TRANSPORTISTA"/>
                        <ComboBox fx:id="cmbTransportista" prefWidth="200" promptText="Todos"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button onAction="#fnBuscar" text="Buscar" styleClass="btn, btn-primary"/>
                </children>
            </HBox>

            <TableView fx:id="tablaEnvio" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                    <TableColumn fx:id="colOrden" prefWidth="80" text="ORDEN"/>
                    <TableColumn fx:id="colCliente" prefWidth="200" text="CLIENTE"/>
                    <TableColumn fx:id="colTransportista" prefWidth="170" text="TRANSPORTISTA"/>
                    <TableColumn fx:id="colEstado" prefWidth="120" text="ESTADO"/>
                    <TableColumn fx:id="colSeguimiento" prefWidth="120" text="N° SEGUIMIENTO"/>
                    <TableColumn fx:id="colFechaEst" prefWidth="110" text="FECHA EST."/>
                    <TableColumn fx:id="colAccion" prefWidth="220" text="ACCIONES"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0 0 0;">
                <children>
                    <Label fx:id="lblTotal" styleClass="text-placeholder" text="Total: 0 envíos"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#fnVolverMenu" text="← Volver" styleClass="btn, btn-secondary"/>
                </children>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer-bar"/>
    </bottom>
</BorderPane>