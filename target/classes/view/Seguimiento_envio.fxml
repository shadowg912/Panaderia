<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="720" prefWidth="1280"
            style="-fx-background-color: #0f172a;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #1e293b;
                     -fx-padding: 16 24;
                     -fx-border-color: #334155;
                     -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-font-size: 10px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #38bdf8;
                              -fx-letter-spacing: 2;"
                       text="PANADERÍA — LOGÍSTICA" />
                <Label style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #f1f5f9;"
                       text="Seguimiento de Envío" />
                <Label style="-fx-font-size: 13px;
                              -fx-text-fill: #38bdf8;"
                       text="Factura: FV-2026-0087 | Cliente: Supermercados del Caribe SRL" />
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #0f172a;
                           -fx-background: #0f172a;
                           -fx-border-color: transparent;">
            <content>
                <VBox spacing="32" style="-fx-padding: 40;">
                    <children>

                        <VBox spacing="24" style="-fx-background-color: #1e293b;
                                                -fx-padding: 30;
                                                -fx-background-radius: 8;
                                                -fx-border-color: #334155;
                                                -fx-border-radius: 8;">
                            <children>
                                <Label style="-fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-font-size: 14px;" text="ESTADO DEL ENVÍO" />

                                <HBox alignment="CENTER" spacing="40">
                                    <children>
                                        <VBox alignment="CENTER" spacing="8" style="-fx-min-width: 200;">
                                            <children>
                                                <Label style="-fx-text-fill: #6366f1; -fx-font-size: 18px; -fx-font-weight: bold;" text="● PENDIENTE" />
                                                <Label style="-fx-text-fill: #f1f5f9; -fx-font-size: 13px;" text="Preparación en bodega" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="8" style="-fx-min-width: 200; -fx-opacity: 0.4;">
                                            <children>
                                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 18px;" text="○ EN CAMINO" />
                                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="En reparto" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="8" style="-fx-min-width: 200; -fx-opacity: 0.4;">
                                            <children>
                                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 18px;" text="○ ENTREGADO" />
                                                <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="Confirmación final" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Separator style="-fx-opacity: 0.1;" />

                                <GridPane hgap="40" alignment="CENTER">
                                    <children>
                                        <HBox spacing="10" GridPane.columnIndex="0">
                                            <Label style="-fx-text-fill: #94a3b8;" text="Fecha estimada:" />
                                            <Label style="-fx-text-fill: #f1f5f9; -fx-font-weight: bold;" text="18/02/2026" />
                                        </HBox>
                                        <HBox spacing="10" GridPane.columnIndex="1">
                                            <Label style="-fx-text-fill: #94a3b8;" text="Costo de envío:" />
                                            <Label style="-fx-text-fill: #38bdf8; -fx-font-weight: bold;" text="RD$ 150.00" />
                                        </HBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="16">
                            <children>
                                <Label style="-fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-font-size: 14px;" text="HISTORIAL DE MOVIMIENTOS" />
                                <ListView prefHeight="180"
                                          style="-fx-background-color: #1e293b;
                                                 -fx-border-color: #334155;
                                                 -fx-background-radius: 8;
                                                 -fx-border-radius: 8;
                                                 -fx-control-inner-background: #1e293b;" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <children>
                                <Button text="Volver"
                                        style="-fx-background-color: #1e293b;
                                               -fx-text-fill: #f1f5f9;
                                               -fx-font-size: 14px;
                                               -fx-border-color: #334155;
                                               -fx-border-radius: 8;
                                               -fx-background-radius: 8;
                                               -fx-padding: 11 28;" />
                                <Button text="Imprimir Guía"
                                        style="-fx-background-color: #1e293b;
                                               -fx-text-fill: #f1f5f9;
                                               -fx-font-size: 14px;
                                               -fx-border-color: #334155;
                                               -fx-border-radius: 8;
                                               -fx-background-radius: 8;
                                               -fx-padding: 11 28;" />
                                <Button text="Actualizar Estado"
                                        style="-fx-background-color: #6366f1;
                                               -fx-text-fill: #fff3eb;
                                               -fx-font-size: 14px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 8;
                                               -fx-padding: 11 28;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #1e293b;
                     -fx-padding: 12;
                     -fx-border-color: #334155;
                     -fx-border-width: 1 0 0 0;" />
    </bottom>
</BorderPane>